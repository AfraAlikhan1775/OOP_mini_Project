<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.*?>

<ScrollPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.technicalofficer.DashboardController"
            fitToWidth="true"
            hbarPolicy="NEVER"
            vbarPolicy="AS_NEEDED"
            style="-fx-background: #f0f2f5; -fx-background-color: #f0f2f5; -fx-border-color: transparent;">

    <VBox spacing="20" style="-fx-padding: 24; -fx-background-color: #f0f2f5;">

        <!-- ═══════════════════════════════════════════════════ -->
        <!--               STAT CARDS ROW                      -->
        <!-- ═══════════════════════════════════════════════════ -->
        <HBox spacing="16">

            <!-- Card 1: Total Students -->
            <VBox HBox.hgrow="ALWAYS" spacing="10"
                  style="-fx-background-color: #ffffff; -fx-background-radius: 12; -fx-border-color: #e5e7eb; -fx-border-radius: 12; -fx-border-width: 1; -fx-padding: 20;">
                <!-- Icon -->
                <Label text="👤"
                       style="-fx-font-size: 20px; -fx-text-fill: #93a8d4;"/>
                <!-- Label -->
                <Label text="Total Students"
                       style="-fx-font-size: 13px; -fx-text-fill: #6b7280;"/>
                <!-- Value -->
                <Label fx:id="totalStudentsLabel" text="24"
                       style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                <!-- Sub -->
                <Label text="ICT2132 Batch"
                       style="-fx-font-size: 12px; -fx-text-fill: #9ca3af;"/>
            </VBox>

            <!-- Card 2: Above 80% -->
            <VBox HBox.hgrow="ALWAYS" spacing="10"
                  style="-fx-background-color: #ffffff; -fx-background-radius: 12; -fx-border-color: #e5e7eb; -fx-border-radius: 12; -fx-border-width: 1; -fx-padding: 20;">
                <!-- Icon -->
                <Label text="✔"
                       style="-fx-font-size: 20px; -fx-text-fill: #22c55e;"/>
                <!-- Label -->
                <Label text="Above 80%"
                       style="-fx-font-size: 13px; -fx-text-fill: #6b7280;"/>
                <!-- Value -->
                <Label fx:id="above80Label" text="17"
                       style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                <!-- Sub -->
                <Label text="Eligible students"
                       style="-fx-font-size: 12px; -fx-text-fill: #9ca3af;"/>
            </VBox>

            <!-- Card 3: Pending Medicals -->
            <VBox HBox.hgrow="ALWAYS" spacing="10"
                  style="-fx-background-color: #ffffff; -fx-background-radius: 12; -fx-border-color: #e5e7eb; -fx-border-radius: 12; -fx-border-width: 1; -fx-padding: 20;">
                <!-- Icon -->
                <Label text="⚠"
                       style="-fx-font-size: 20px; -fx-text-fill: #f59e0b;"/>
                <!-- Label -->
                <Label text="Pending Medicals"
                       style="-fx-font-size: 13px; -fx-text-fill: #6b7280;"/>
                <!-- Value -->
                <Label fx:id="pendingMedicalsLabel" text="3"
                       style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                <!-- Sub -->
                <Label text="Awaiting review"
                       style="-fx-font-size: 12px; -fx-text-fill: #9ca3af;"/>
            </VBox>

            <!-- Card 4: Below 80% -->
            <VBox HBox.hgrow="ALWAYS" spacing="10"
                  style="-fx-background-color: #ffffff; -fx-background-radius: 12; -fx-border-color: #e5e7eb; -fx-border-radius: 12; -fx-border-width: 1; -fx-padding: 20;">
                <!-- Icon -->
                <Label text="⊠"
                       style="-fx-font-size: 20px; -fx-text-fill: #ef4444;"/>
                <!-- Label -->
                <Label text="Below 80%"
                       style="-fx-font-size: 13px; -fx-text-fill: #6b7280;"/>
                <!-- Value -->
                <Label fx:id="below80Label" text="7"
                       style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                <!-- Sub -->
                <Label text="At risk"
                       style="-fx-font-size: 12px; -fx-text-fill: #9ca3af;"/>
            </VBox>

        </HBox>

        <!-- ═══════════════════════════════════════════════════ -->
        <!--          BOTTOM ROW: ATTENDANCE + NOTICES          -->
        <!-- ═══════════════════════════════════════════════════ -->
        <HBox spacing="16">

            <!-- ─── Recent Attendance ─── -->
            <VBox HBox.hgrow="ALWAYS" spacing="0"
                  style="-fx-background-color: #ffffff; -fx-background-radius: 12; -fx-border-color: #e5e7eb; -fx-border-radius: 12; -fx-border-width: 1; -fx-padding: 20;">

                <!-- Header -->
                <HBox alignment="CENTER_LEFT" style="-fx-padding: 0 0 16 0;">
                    <Label text="Recent Attendance"
                           style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="Today"
                           style="-fx-background-color: #eff6ff; -fx-background-radius: 6; -fx-text-fill: #3b6ad4; -fx-font-size: 12px; -fx-padding: 4 10 4 10;"/>
                </HBox>

                <!-- Separator -->
                <Separator style="-fx-background-color: #f3f4f6;"/>
                <VBox spacing="0" fx:id="attendanceList" style="-fx-padding: 8 0 0 0;">

                    <!-- Row 1: 87% -->
                    <HBox alignment="CENTER_LEFT" style="-fx-padding: 12 0 12 0; -fx-border-color: transparent transparent #f3f4f6 transparent; -fx-border-width: 0 0 1 0;">
                        <VBox spacing="3" HBox.hgrow="ALWAYS">
                            <Label text="ICT2132 – S/ICT/21/001"
                                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                            <Label text="OOP Practicum · Session 9"
                                   style="-fx-font-size: 11px; -fx-text-fill: #9ca3af;"/>
                        </VBox>
                        <VBox spacing="4" alignment="CENTER_RIGHT" minWidth="80">
                            <Label text="87%"
                                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #22c55e;"/>
                            <HBox spacing="2" alignment="CENTER_RIGHT">
                                <Rectangle width="60" height="4" arcWidth="4" arcHeight="4" fill="#22c55e"/>
                                <Rectangle width="10" height="4" arcWidth="4" arcHeight="4" fill="#e5e7eb"/>
                            </HBox>
                        </VBox>
                    </HBox>

                    <!-- Row 2: 80% -->
                    <HBox alignment="CENTER_LEFT" style="-fx-padding: 12 0 12 0; -fx-border-color: transparent transparent #f3f4f6 transparent; -fx-border-width: 0 0 1 0;">
                        <VBox spacing="3" HBox.hgrow="ALWAYS">
                            <Label text="ICT2132 – S/ICT/21/002"
                                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                            <Label text="OOP Practicum · Session 9"
                                   style="-fx-font-size: 11px; -fx-text-fill: #9ca3af;"/>
                        </VBox>
                        <VBox spacing="4" alignment="CENTER_RIGHT" minWidth="80">
                            <Label text="80%"
                                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #f59e0b;"/>
                            <HBox spacing="2" alignment="CENTER_RIGHT">
                                <Rectangle width="55" height="4" arcWidth="4" arcHeight="4" fill="#f59e0b"/>
                                <Rectangle width="15" height="4" arcWidth="4" arcHeight="4" fill="#e5e7eb"/>
                            </HBox>
                        </VBox>
                    </HBox>

                    <!-- Row 3: 67% -->
                    <HBox alignment="CENTER_LEFT" style="-fx-padding: 12 0 12 0; -fx-border-color: transparent transparent #f3f4f6 transparent; -fx-border-width: 0 0 1 0;">
                        <VBox spacing="3" HBox.hgrow="ALWAYS">
                            <Label text="ICT2132 – S/ICT/21/004"
                                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                            <Label text="OOP Practicum · Session 9"
                                   style="-fx-font-size: 11px; -fx-text-fill: #9ca3af;"/>
                        </VBox>
                        <VBox spacing="4" alignment="CENTER_RIGHT" minWidth="80">
                            <Label text="67%"
                                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #ef4444;"/>
                            <HBox spacing="2" alignment="CENTER_RIGHT">
                                <Rectangle width="45" height="4" arcWidth="4" arcHeight="4" fill="#ef4444"/>
                                <Rectangle width="25" height="4" arcWidth="4" arcHeight="4" fill="#e5e7eb"/>
                            </HBox>
                        </VBox>
                    </HBox>

                    <!-- Row 4: 93% -->
                    <HBox alignment="CENTER_LEFT" style="-fx-padding: 12 0 0 0;">
                        <VBox spacing="3" HBox.hgrow="ALWAYS">
                            <Label text="ICT2132 – S/ICT/21/007"
                                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                            <Label text="OOP Practicum · Session 9"
                                   style="-fx-font-size: 11px; -fx-text-fill: #9ca3af;"/>
                        </VBox>
                        <VBox spacing="4" alignment="CENTER_RIGHT" minWidth="80">
                            <Label text="93%"
                                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #22c55e;"/>
                            <HBox spacing="2" alignment="CENTER_RIGHT">
                                <Rectangle width="65" height="4" arcWidth="4" arcHeight="4" fill="#22c55e"/>
                                <Rectangle width="5" height="4" arcWidth="4" arcHeight="4" fill="#e5e7eb"/>
                            </HBox>
                        </VBox>
                    </HBox>

                </VBox>
            </VBox>

            <!-- ─── Latest Notices ─── -->
            <VBox prefWidth="280" minWidth="280" maxWidth="280" spacing="0"
                  style="-fx-background-color: #ffffff; -fx-background-radius: 12; -fx-border-color: #e5e7eb; -fx-border-radius: 12; -fx-border-width: 1; -fx-padding: 20;">

                <!-- Header -->
                <Label text="Latest Notices"
                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #111827; -fx-padding: 0 0 16 0;"/>

                <Separator style="-fx-background-color: #f3f4f6;"/>

                <VBox spacing="0" style="-fx-padding: 8 0 0 0;">

                    <!-- Notice 1 -->
                    <VBox spacing="3" style="-fx-padding: 12 0 12 0; -fx-border-color: transparent transparent #f3f4f6 transparent; -fx-border-width: 0 0 1 0;">
                        <Label text="Final Exam Schedule Released"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                        <Label text="20 Apr 2026"
                               style="-fx-font-size: 11px; -fx-text-fill: #9ca3af;"/>
                    </VBox>

                    <!-- Notice 2 -->
                    <VBox spacing="3" style="-fx-padding: 12 0 12 0; -fx-border-color: transparent transparent #f3f4f6 transparent; -fx-border-width: 0 0 1 0;">
                        <Label text="Medical Submission Deadline"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                        <Label text="18 Apr 2026"
                               style="-fx-font-size: 11px; -fx-text-fill: #9ca3af;"/>
                    </VBox>

                    <!-- Notice 3 -->
                    <VBox spacing="3" style="-fx-padding: 12 0 12 0; -fx-border-color: transparent transparent #f3f4f6 transparent; -fx-border-width: 0 0 1 0;">
                        <Label text="Lab Maintenance – Block B"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                        <Label text="15 Apr 2026"
                               style="-fx-font-size: 11px; -fx-text-fill: #9ca3af;"/>
                    </VBox>

                    <!-- Notice 4 -->
                    <VBox spacing="3" style="-fx-padding: 12 0 0 0;">
                        <Label text="Mini Project Submission Reminder"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                        <Label text="12 Apr 2026"
                               style="-fx-font-size: 11px; -fx-text-fill: #9ca3af;"/>
                    </VBox>

                </VBox>
            </VBox>

        </HBox>
    </VBox>
</ScrollPane>
