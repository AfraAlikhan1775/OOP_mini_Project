<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.TimetableController"
      spacing="0" style="-fx-background-color:transparent;">

    <VBox styleClass="card" spacing="12">

        <HBox alignment="CENTER_LEFT" spacing="8">
            <Label styleClass="card-title" text="Department Timetable"/>
            <Label styleClass="badge-blue" text="Semester I 2025/26"/>
        </HBox>

        <TableView fx:id="tblTimetable" VBox.vgrow="ALWAYS" minHeight="350">
            <columns>
                <TableColumn fx:id="colDay"     text="Day"          prefWidth="100"/>
                <TableColumn fx:id="colTime"    text="Time"         prefWidth="130"/>
                <TableColumn fx:id="colSubject" text="Subject"      prefWidth="220"/>
                <TableColumn fx:id="colType"    text="Type"         prefWidth="100"/>
                <TableColumn fx:id="colVenue"   text="Venue"        prefWidth="130"/>
                <TableColumn fx:id="colCredits" text="Credits"      prefWidth="70"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>

        <!-- Legend -->
        <HBox spacing="16" style="-fx-padding: 6 0 0 0;">
            <HBox spacing="6" alignment="CENTER_LEFT">
                <StackPane style="-fx-background-color:#f0fdf4; -fx-min-width:16; -fx-min-height:16;
                                  -fx-background-radius:3; -fx-border-color:#d1fae5; -fx-border-width:1; -fx-border-radius:3;"/>
                <Label text="Theory" style="-fx-font-size:11px; -fx-text-fill:#6b7280;"/>
            </HBox>
            <HBox spacing="6" alignment="CENTER_LEFT">
                <StackPane style="-fx-background-color:#fffbeb; -fx-min-width:16; -fx-min-height:16;
                                  -fx-background-radius:3; -fx-border-color:#fde68a; -fx-border-width:1; -fx-border-radius:3;"/>
                <Label text="Practical" style="-fx-font-size:11px; -fx-text-fill:#6b7280;"/>
            </HBox>
        </HBox>

    </VBox>

</VBox>
