<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<BorderPane prefWidth="980.0" prefHeight="760.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            >

   <top>
      <HBox alignment="CENTER" prefHeight="90.0" style="-fx-background-color: #0b1f36;">
         <children>
            <VBox alignment="CENTER" spacing="5">
               <children>
                  <Label text="Student Registration 📝" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="20.0"/>
                     </font>
                  </Label>
                  <Label text="UoR - FoT" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="16.0"/>
                     </font>
                  </Label>
               </children>
            </VBox>
         </children>
      </HBox>
   </top>

   <center>
      <ScrollPane fitToWidth="true" pannable="true" style="-fx-background-color:#eaf1f8;">
         <content>
            <VBox spacing="20" style="-fx-background-color:#eaf1f8;">
               <padding>
                  <Insets top="20" right="20" bottom="20" left="20"/>
               </padding>

               <children>

                  <VBox spacing="15" style="-fx-background-color:white; -fx-background-radius:10; -fx-padding:20;">
                     <children>
                        <Label text="Basic Information" style="-fx-font-size:16px; -fx-font-weight:bold;"/>

                        <HBox spacing="30">
                           <children>

                              <GridPane hgap="15" vgap="18">
                                 <children>
                                    <Label text="First Name:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                    <TextField fx:id="firstNameField" promptText="Enter first name" prefWidth="220"
                                               GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                                    <Label text="Last Name:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                                    <TextField fx:id="lastNameField" promptText="Enter last name" prefWidth="220"
                                               GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                                    <Label text="Registration No:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                    <TextField fx:id="registrationNoField" promptText="Enter registration number" prefWidth="220"
                                               GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                                    <Label text="NIC:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                                    <TextField fx:id="nicField" promptText="Enter NIC" prefWidth="220"
                                               GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                                    <Label text="Date of Birth:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                                    <DatePicker fx:id="dobPicker" prefWidth="220"
                                                GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                                    <Label text="Gender:" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
                                    <HBox spacing="15" alignment="CENTER_LEFT"
                                          GridPane.rowIndex="2" GridPane.columnIndex="3">
                                       <children>
                                          <RadioButton fx:id="maleRadio" text="Male">
                                             <toggleGroup>
                                                <ToggleGroup fx:id="genderGroup"/>
                                             </toggleGroup>
                                          </RadioButton>
                                          <RadioButton fx:id="femaleRadio" text="Female" toggleGroup="$genderGroup"/>
                                       </children>
                                    </HBox>

                                    <Label text="Registration Picture:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                                    <Button text="Upload Image" fx:id="uploadImageButton"
                                             prefWidth="140"
                                            GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                                    <Label text="District:" GridPane.rowIndex="3" GridPane.columnIndex="2"/>
                                    <ComboBox fx:id="districtComboBox" prefWidth="220"
                                              GridPane.rowIndex="3" GridPane.columnIndex="3">
                                       <items>
                                          <FXCollections fx:factory="observableArrayList">
                                             <String fx:value="Ampara"/>
                                             <String fx:value="Anuradhapura"/>
                                             <String fx:value="Badulla"/>
                                             <String fx:value="Batticaloa"/>
                                             <String fx:value="Colombo"/>
                                             <String fx:value="Galle"/>
                                             <String fx:value="Gampaha"/>
                                             <String fx:value="Hambantota"/>
                                             <String fx:value="Jaffna"/>
                                             <String fx:value="Kalutara"/>
                                             <String fx:value="Kandy"/>
                                             <String fx:value="Kegalle"/>
                                             <String fx:value="Kilinochchi"/>
                                             <String fx:value="Kurunegala"/>
                                             <String fx:value="Mannar"/>
                                             <String fx:value="Matale"/>
                                             <String fx:value="Matara"/>
                                             <String fx:value="Monaragala"/>
                                             <String fx:value="Mullaitivu"/>
                                             <String fx:value="Nuwara Eliya"/>
                                             <String fx:value="Polonnaruwa"/>
                                             <String fx:value="Puttalam"/>
                                             <String fx:value="Ratnapura"/>
                                             <String fx:value="Trincomalee"/>
                                             <String fx:value="Vavuniya"/>
                                          </FXCollections>
                                       </items>
                                    </ComboBox>
                                 </children>
                              </GridPane>

                              <VBox alignment="TOP_CENTER" spacing="10" prefWidth="190"
                                    style="-fx-background-color:#f4f6f8; -fx-background-radius:10; -fx-padding:15;">
                                 <children>
                                    <Label text="Photo Preview" style="-fx-font-weight:bold;"/>
                                    <ImageView fx:id="studentImageView"
                                               fitWidth="150"
                                               fitHeight="150"
                                               preserveRatio="true"/>
                                 </children>
                              </VBox>

                           </children>
                        </HBox>
                     </children>
                  </VBox>

                  <VBox spacing="15" style="-fx-background-color:white; -fx-background-radius:10; -fx-padding:20;">
                     <children>
                        <Label text="Contact Information" style="-fx-font-size:16px; -fx-font-weight:bold;"/>

                        <GridPane hgap="15" vgap="15">
                           <children>
                              <Label text="Email:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                              <TextField fx:id="emailField" promptText="Enter email" prefWidth="220"
                                         GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                              <Label text="Phone:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                              <TextField fx:id="phoneField" promptText="Enter phone number" prefWidth="220"
                                         GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                              <Label text="Address:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                              <TextArea fx:id="addressArea" prefHeight="80" prefWidth="520"
                                        promptText="Enter address"
                                        GridPane.rowIndex="1" GridPane.columnIndex="1" GridPane.columnSpan="3"/>
                           </children>
                        </GridPane>
                     </children>
                  </VBox>

                  <VBox spacing="15" style="-fx-background-color:white; -fx-background-radius:10; -fx-padding:20;">
                     <children>
                        <Label text="Academic Information" style="-fx-font-size:16px; -fx-font-weight:bold;"/>

                        <GridPane hgap="15" vgap="15">
                           <children>
                              <Label text="Department:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                              <ComboBox fx:id="departmentComboBox" prefWidth="220"
                                        GridPane.rowIndex="0" GridPane.columnIndex="1">
                                 <items>
                                    <FXCollections fx:factory="observableArrayList">
                                       <String fx:value="ICT"/>
                                       <String fx:value="BST"/>
                                       <String fx:value="ET"/>
                                    </FXCollections>
                                 </items>
                              </ComboBox>

                              <Label text="Course:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                              <ComboBox fx:id="courseComboBox" prefWidth="220"
                                        GridPane.rowIndex="0" GridPane.columnIndex="3">
                                 <items>
                                    <FXCollections fx:factory="observableArrayList">
                                       <String fx:value="BICT"/>
                                       <String fx:value="BST"/>
                                       <String fx:value="BET"/>
                                    </FXCollections>
                                 </items>
                              </ComboBox>

                              <Label text="Year:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                              <TextField fx:id="yearField" promptText="Enter year" prefWidth="220"
                                         GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                              <Label text="Batch:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                              <TextField fx:id="batchField" promptText="Enter batch" prefWidth="220"
                                         GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                              <Label text="Mentor ID:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                              <TextField fx:id="mentorIdField" promptText="Enter lecturer mentor ID" prefWidth="220"
                                         GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                           </children>
                        </GridPane>
                     </children>
                  </VBox>

                  <VBox spacing="15" style="-fx-background-color:white; -fx-background-radius:10; -fx-padding:20;">
                     <children>
                        <Label text="Guardian Information" style="-fx-font-size:16px; -fx-font-weight:bold;"/>

                        <GridPane hgap="15" vgap="15">
                           <children>
                              <Label text="Guardian Name:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                              <TextField fx:id="guardianNameField" promptText="Enter guardian name" prefWidth="220"
                                         GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                              <Label text="Guardian Phone:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                              <TextField fx:id="guardianPhoneField" promptText="Enter guardian phone" prefWidth="220"
                                         GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                              <Label text="Relationship:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                              <TextField fx:id="relationshipField" promptText="Enter relationship" prefWidth="220"
                                         GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                           </children>
                        </GridPane>
                     </children>
                  </VBox>

                  <HBox alignment="CENTER" spacing="15">
                     <children>
                        <Button text="Register" prefWidth="120" style="-fx-background-color:#0b1f36; -fx-text-fill:white;"/>
                        <Button text="Clear" prefWidth="120"/>
                        <Button text="Back" prefWidth="120"/>
                     </children>
                  </HBox>

               </children>
            </VBox>
         </content>
      </ScrollPane>
   </center>

</BorderPane>