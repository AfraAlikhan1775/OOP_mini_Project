<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="748.0" prefWidth="1300.0" stylesheets="@adminstyle.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.controller.admin.StudentController">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="46.0" spacing="12.0" style="-fx-background-color: #0b1f36; -fx-padding: 10 20 10 20;">
            <children>
                <Label text="Student Management 🎓" textFill="WHITE">
                    <font>
                        <Font size="18.0" />
                    </font>
                </Label>

                <Region HBox.hgrow="ALWAYS" />

                <TextField fx:id="searchField" prefHeight="26.0" prefWidth="278.0" promptText="Search student..." />
                <Button mnemonicParsing="false" onAction="#handleSearch" style="-fx-background-color: #122c4a;" text="🔍" textFill="WHITE" />

                <Label text="Filter" textFill="WHITE">
                    <font>
                        <Font name="Nirmala UI" size="17.0" />
                    </font>
                </Label>

                <ComboBox fx:id="categoryComboBox" onAction="#handleFilter" prefHeight="26.0" prefWidth="158.0" />

                <MenuButton mnemonicParsing="false" style="-fx-background-color: #122c4a; -fx-font-size: 18px;" text="➕" textFill="WHITE">
                    <items>
                        <MenuItem mnemonicParsing="false" onAction="#navigateAddStudent" text="Add student" />
                        <MenuItem mnemonicParsing="false" onAction="#navigateAddLecturer" text="Add lecturer" />
                        <MenuItem mnemonicParsing="false" text="Add Course" />
                        <MenuItem mnemonicParsing="false" text="Add TO" />
                        <MenuItem mnemonicParsing="false" text="Add Time table" />
                        <MenuItem mnemonicParsing="false" text="Add Notice" />
                    </items>
                </MenuButton>
            </children>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" pannable="true" style="-fx-background-color:#eaf1f8;">
            <content>
                <VBox fx:id="studentCardContainer" spacing="18.0" style="-fx-background-color:#eaf1f8;">
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>
