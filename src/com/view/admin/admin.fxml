<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="800" prefWidth="1200" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.controller.admin.AdminController">

    <left>
        <VBox prefWidth="220" spacing="10" style="-fx-background-color:#0b1f36; -fx-padding:15;">
            <children>
                <Label style="-fx-text-fill:white; -fx-font-size:18;" text="FOT Management" />

                <Label style="-fx-text-fill:#7f9bb3;" text="OVERVIEW" />
                <Button fx:id="dashboardBtn" onAction="#handleDashboard" text="Dashboard" />

                <Label style="-fx-text-fill:#7f9bb3;" text="USERS" />
                <Button onAction="#handleUserprofile" text="Student Management  🎓" />
                <Button onAction="#handleLecturer" text="Lecturers" />
                <Button onAction="#handleTO" text="Tech Officers" />
                <Button onAction="#handleStudents" text="Undergraduates" />

                <Label style="-fx-text-fill:#7f9bb3;" text="ACADEMIC" />
                <Button onAction="#handleCourse" text="Courses" />
                <Button onAction="#handleTimetable" text="Timetables" />
                <Button onAction="#handleNotice" text="Notices" />
            </children>
        </VBox>
    </left>

    <top>
        <HBox spacing="10" style="-fx-background-color:#0f2a44; -fx-padding:10;">
            <children>
                <Label style="-fx-text-fill:white; -fx-font-size:20;" text="Adddmin Dashboard" />
                <Region HBox.hgrow="ALWAYS" />
                <Label style="-fx-text-fill:white;" text="08 April 2026" />
                <Label style="-fx-text-fill:#00ff99;" text="● Online" />
            </children>
        </HBox>
    </top>

    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: #eaf1f8;" />
    </center>

</BorderPane>
