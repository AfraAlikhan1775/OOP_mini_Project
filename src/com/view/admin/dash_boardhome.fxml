<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="22" style="-fx-padding:25; -fx-background-color:#eaf1f8;"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.controller.admin.DashboardHomeController">

   <children>

      <Label text="Dashboard Overview"
             style="-fx-font-size:26px; -fx-font-weight:bold; -fx-text-fill:#0b1f36;" />

      <!-- COUNT CARDS -->
      <HBox spacing="18">
         <children>

            <VBox HBox.hgrow="ALWAYS" prefHeight="130"
                  style="-fx-background-color:#122c4a; -fx-padding:22; -fx-background-radius:18;">
               <children>
                  <Label text="Lecturers" style="-fx-text-fill:white; -fx-font-size:16;" />
                  <Label fx:id="lecturerCountLabel" text="0"
                         style="-fx-text-fill:white; -fx-font-size:34; -fx-font-weight:bold;" />
                  <Label text="Active faculty" style="-fx-text-fill:#9fb3c8;" />
               </children>
            </VBox>

            <VBox HBox.hgrow="ALWAYS" prefHeight="130"
                  style="-fx-background-color:#122c4a; -fx-padding:22; -fx-background-radius:18;">
               <children>
                  <Label text="Tech Officers" style="-fx-text-fill:white; -fx-font-size:16;" />
                  <Label fx:id="techOfficerCountLabel" text="0"
                         style="-fx-text-fill:white; -fx-font-size:34; -fx-font-weight:bold;" />
                  <Label text="Registered staff" style="-fx-text-fill:#d7f5e5;" />
               </children>
            </VBox>

            <VBox HBox.hgrow="ALWAYS" prefHeight="130"
                  style="-fx-background-color:#122c4a; -fx-padding:22; -fx-background-radius:18;">
               <children>
                  <Label text="Undergraduates" style="-fx-text-fill:white; -fx-font-size:16;" />
                  <Label fx:id="studentCountLabel" text="0"
                         style="-fx-text-fill:white; -fx-font-size:34; -fx-font-weight:bold;" />
                  <Label text="Enrolled students" style="-fx-text-fill:#fff1b8;" />
               </children>
            </VBox>

            <VBox HBox.hgrow="ALWAYS" prefHeight="130"
                  style="-fx-background-color:#122c4a; -fx-padding:22; -fx-background-radius:18;">
               <children>
                  <Label text="Courses" style="-fx-text-fill:white; -fx-font-size:16;" />
                  <Label fx:id="courseCountLabel" text="0"
                         style="-fx-text-fill:white; -fx-font-size:34; -fx-font-weight:bold;" />
                  <Label text="Available courses" style="-fx-text-fill:#ffd6d6;" />
               </children>
            </VBox>

         </children>
      </HBox>

      <!-- RECENT DETAILS -->
      <HBox spacing="22" VBox.vgrow="ALWAYS">
         <children>

            <VBox spacing="12" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS"
                  style="-fx-background-color:white; -fx-padding:20; -fx-background-radius:18; -fx-border-color:#d9e2ec; -fx-border-radius:18;">
               <children>
                  <Label text="Recent Users"
                         style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:#0b1f36;" />
                  <ListView fx:id="recentUsersList" VBox.vgrow="ALWAYS" prefHeight="420" />
               </children>
            </VBox>

            <VBox spacing="12" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS"
                  style="-fx-background-color:white; -fx-padding:20; -fx-background-radius:18; -fx-border-color:#d9e2ec; -fx-border-radius:18;">
               <children>
                  <Label text="Recent Notices"
                         style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:#0b1f36;" />
                  <ListView fx:id="recentNoticesList" VBox.vgrow="ALWAYS" prefHeight="420" />
               </children>
            </VBox>

         </children>
      </HBox>

   </children>
</VBox>