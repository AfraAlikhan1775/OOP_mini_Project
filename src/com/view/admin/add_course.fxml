<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="520.0" prefWidth="760.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.controller.admin.AddCourseController">

    <top>
        <HBox alignment="CENTER" prefHeight="80.0" style="-fx-background-color: #0b1f36;">
            <children>
                <Label text="Add Course 📘" textFill="WHITE">
                    <font>
                        <Font size="22.0"/>
                    </font>
                </Label>
            </children>
        </HBox>
    </top>

    <center>
        <VBox spacing="20.0" style="-fx-background-color:#eaf1f8;">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <children>
                <VBox spacing="15.0" style="-fx-background-color:white; -fx-background-radius:12; -fx-padding:20;">
                    <children>
                        <Label text="Course Information" style="-fx-font-size:16px; -fx-font-weight:bold;"/>

                        <GridPane hgap="15" vgap="15">
                            <children>
                                <Label text="Department:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                <ComboBox fx:id="departmentComboBox" prefWidth="220" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                                <Label text="Year:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                                <ComboBox fx:id="yearComboBox" prefWidth="220" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                                <Label text="Semester:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                <ComboBox fx:id="semesterComboBox" prefWidth="220" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                                <Label text="Course ID:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                                <TextField fx:id="courseIdField" prefWidth="220" promptText="Enter course ID" GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                                <Label text="Course Name:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                                <TextField fx:id="courseNameField" prefWidth="220" promptText="Enter course name" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                                <Label text="Coordinator ID:" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
                                <TextField fx:id="coordinatorField" prefWidth="220" promptText="Enter lecturer emp_id" GridPane.rowIndex="2" GridPane.columnIndex="3"/>

                                <Label text="Credits:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                                <TextField fx:id="creditsField" prefWidth="220" promptText="Enter credits" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                                <Label text="Course Image:" GridPane.rowIndex="3" GridPane.columnIndex="2"/>
                                <Button fx:id="uploadImageBtn" text="Upload Image" onAction="#handleUploadImage" GridPane.rowIndex="3" GridPane.columnIndex="3"/>
                            </children>
                        </GridPane>

                        <VBox alignment="CENTER" spacing="10">
                            <children>
                                <Label text="Preview"/>
                                <ImageView fx:id="courseImageView" fitHeight="120" fitWidth="140" preserveRatio="true"/>
                            </children>
                        </VBox>
                    </children>
                </VBox>

                <HBox alignment="CENTER" spacing="15">
                    <children>
                        <Button text="Add Course" onAction="#handleAddCourse"
                                style="-fx-background-color:#0b1f36; -fx-text-fill:white;"
                                prefWidth="140"/>
                        <Button text="Clear" onAction="#handleClear" prefWidth="120"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>
</BorderPane>