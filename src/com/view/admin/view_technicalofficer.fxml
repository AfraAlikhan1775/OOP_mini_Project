<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<VBox spacing="18"
      style="-fx-padding:25; -fx-background-color:#eaf1f8;"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.controller.admin.ViewTechnicalOfficerController">

    <Label text="Technical Officer Details"
           style="-fx-font-size:24; -fx-font-weight:bold; -fx-text-fill:#0b1f36;"/>

    <HBox spacing="25">
        <ImageView fx:id="profileImage"
                   fitWidth="130"
                   fitHeight="150"
                   preserveRatio="true"/>

        <GridPane hgap="20" vgap="12">
            <Label text="First Name:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <Label fx:id="firstNameLabel" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

            <Label text="Last Name:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <Label fx:id="lastNameLabel" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

            <Label text="Employee ID:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <Label fx:id="empIdLabel" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

            <Label text="NIC:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <Label fx:id="nicLabel" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

            <Label text="DOB:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
            <Label fx:id="dobLabel" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

            <Label text="Gender:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
            <Label fx:id="genderLabel" GridPane.rowIndex="5" GridPane.columnIndex="1"/>

            <Label text="District:" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
            <Label fx:id="districtLabel" GridPane.rowIndex="6" GridPane.columnIndex="1"/>

            <Label text="Email:" GridPane.rowIndex="7" GridPane.columnIndex="0"/>
            <Label fx:id="emailLabel" GridPane.rowIndex="7" GridPane.columnIndex="1"/>

            <Label text="Phone:" GridPane.rowIndex="8" GridPane.columnIndex="0"/>
            <Label fx:id="phoneLabel" GridPane.rowIndex="8" GridPane.columnIndex="1"/>

            <Label text="Address:" GridPane.rowIndex="9" GridPane.columnIndex="0"/>
            <Label fx:id="addressLabel" GridPane.rowIndex="9" GridPane.columnIndex="1"/>

            <Label text="Department:" GridPane.rowIndex="10" GridPane.columnIndex="0"/>
            <Label fx:id="departmentLabel" GridPane.rowIndex="10" GridPane.columnIndex="1"/>

            <Label text="Position:" GridPane.rowIndex="11" GridPane.columnIndex="0"/>
            <Label fx:id="positionLabel" GridPane.rowIndex="11" GridPane.columnIndex="1"/>

            <Label text="Shift Type:" GridPane.rowIndex="12" GridPane.columnIndex="0"/>
            <Label fx:id="shiftTypeLabel" GridPane.rowIndex="12" GridPane.columnIndex="1"/>

            <Label text="Assigned Lab:" GridPane.rowIndex="13" GridPane.columnIndex="0"/>
            <Label fx:id="assignedLabLabel" GridPane.rowIndex="13" GridPane.columnIndex="1"/>
        </GridPane>
    </HBox>

    <HBox spacing="15">
        <Button text="Update"
                onAction="#handleUpdate"
                prefWidth="120"
                style="-fx-background-color:#0b1f36; -fx-text-fill:white;"/>

        <Button text="Close"
                onAction="#handleClose"
                prefWidth="120"/>
    </HBox>

</VBox>