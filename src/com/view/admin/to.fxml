<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="748.0" prefWidth="1300.0"
            stylesheets="@adminstyle.css"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.controller.admin.TOController">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="60.0" spacing="12"
              style="-fx-background-color:#0b1f36; -fx-padding:10 20 10 20;">

            <Label text="Technical Officer Management 🛠️" textFill="WHITE">
                <font>
                    <Font size="18.0"/>
                </font>
            </Label>

            <Region HBox.hgrow="ALWAYS"/>

            <TextField fx:id="searchField" prefWidth="280"
                       promptText="Search technical officer"/>

            <Button onAction="#handleSearch"
                    style="-fx-background-color:#122c4a; -fx-text-fill:white;"
                    text="🔍"/>

            <Label text="Filter" textFill="WHITE"/>

            <ComboBox fx:id="categoryComboBox" onAction="#handleFilter" prefWidth="150"/>

            <Button onAction="#navigateAddTO"
                    style="-fx-background-color:#122c4a; -fx-text-fill:white; -fx-font-weight:bold;"
                    text="➕"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color:#eaf1f8;">
            <content>
                <VBox fx:id="officerCardContainer" spacing="15"
                      style="-fx-background-color:#eaf1f8; -fx-padding:20;">
                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>