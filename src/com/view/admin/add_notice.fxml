<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="560.0" prefWidth="760.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.controller.admin.AddNoticeController">

    <top>
        <HBox alignment="CENTER" prefHeight="80.0" style="-fx-background-color: #0b1f36;">
            <children>
                <Label text="Add Notice 📄" textFill="WHITE">
                    <font>
                        <Font size="22.0"/>
                    </font>
                </Label>
            </children>
        </HBox>
    </top>

    <center>
        <VBox spacing="20" style="-fx-background-color:#eaf1f8;">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <children>
                <VBox spacing="15" style="-fx-background-color:white; -fx-background-radius:12; -fx-padding:20;">
                    <children>
                        <Label text="Notice Information" style="-fx-font-size:16px; -fx-font-weight:bold;"/>

                        <GridPane hgap="15" vgap="15">
                            <children>
                                <Label text="Title:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                <TextField fx:id="titleField" prefWidth="220" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                                <Label text="Role:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                                <ComboBox fx:id="roleComboBox" prefWidth="220" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                                <Label text="Batch:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                <ComboBox fx:id="batchComboBox" prefWidth="220" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                                <Label text="Department:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                                <ComboBox fx:id="departmentComboBox" prefWidth="220" GridPane.rowIndex="1" GridPane.columnIndex="3"/>
                            </children>
                        </GridPane>

                        <Label text="Description:"/>
                        <TextArea fx:id="descriptionArea" prefHeight="120" wrapText="true"/>

                        <HBox spacing="15" alignment="CENTER_LEFT">
                            <children>
                                <Button text="Choose PDF" onAction="#handleChoosePdf"/>
                                <Label fx:id="selectedPdfLabel" text="No PDF selected"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <HBox alignment="CENTER" spacing="15">
                    <children>
                        <Button text="Save Notice" onAction="#handleSaveNotice"
                                style="-fx-background-color:#0b1f36; -fx-text-fill:white;"
                                prefWidth="140"/>
                        <Button text="Clear" onAction="#handleClear" prefWidth="120"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>
</BorderPane>