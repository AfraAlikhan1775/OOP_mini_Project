<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.controller.techOfficerControllers.TOMedicalController"
            style="-fx-background-color:#f5f7fa; -fx-padding:20;">

    <top>
        <VBox spacing="12">
            <Label text="Medical Management"
                   style="-fx-font-size:24px; -fx-font-weight:bold; -fx-text-fill:#0b1f36;" />

            <HBox spacing="10">
                <TextField fx:id="searchField" promptText="Search student/reg no" prefWidth="250" />
                <Button text="Search" onAction="#handleSearch" />
                <Button text="Refresh" onAction="#handleRefresh" />
                <ComboBox fx:id="departmentFilter" promptText="Department" prefWidth="140" />
                <ComboBox fx:id="statusFilter" promptText="Status" prefWidth="140" />
                <Button text="+ Add Medical" onAction="#handleAddMedical" />
            </HBox>
        </VBox>
    </top>

    <center>
        <TableView fx:id="medicalTable" prefHeight="500">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="60" />
                <TableColumn fx:id="colStudentId" text="Student ID" prefWidth="140" />
                <TableColumn fx:id="colDepartment" text="Department" prefWidth="120" />
                <TableColumn fx:id="colStartDate" text="Start Date" prefWidth="120" />
                <TableColumn fx:id="colEndDate" text="End Date" prefWidth="120" />
                <TableColumn fx:id="colReason" text="Reason" prefWidth="220" />
                <TableColumn fx:id="colStatus" text="Status" prefWidth="120" />
                <TableColumn fx:id="colActions" text="Actions" prefWidth="150" />
            </columns>
        </TableView>
    </center>

    <bottom>
        <Label fx:id="statusLabel"
               text=""
               style="-fx-padding:10 0 0 0; -fx-text-fill:#0b1f36;" />
    </bottom>

</BorderPane>