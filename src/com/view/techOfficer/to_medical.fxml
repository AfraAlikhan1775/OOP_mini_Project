<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="15" style="-fx-padding: 25;"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.controller.techOfficerControllers.TOMedicalController">

    <!-- Page Header -->
    <HBox alignment="CENTER_LEFT" spacing="15" styleClass="page-header"
          style="-fx-background-radius: 12;">
        <padding>
            <Insets top="12" right="20" bottom="12" left="20" />
        </padding>
        <Label styleClass="page-header-title" text="🏥  Medical Records Management" />
        <Region HBox.hgrow="ALWAYS" />
        <Button onAction="#handleAddMedical" styleClass="btn-primary" text="+ Add Medical" />
    </HBox>

    <!-- Filter Bar -->
    <HBox spacing="12" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" styleClass="search-field" promptText="Search by Student ID, Reason..." prefWidth="280" />
        <Button onAction="#handleSearch" styleClass="btn-primary" text="🔍" />
        <ComboBox fx:id="departmentFilter" promptText="Department" prefWidth="150" />
        <ComboBox fx:id="statusFilter" promptText="Status" prefWidth="130" />
        <Region HBox.hgrow="ALWAYS" />
        <Button onAction="#handleRefresh" styleClass="btn-secondary" text="↻ Refresh" />
    </HBox>

    <!-- Medical Records Table -->
    <TableView fx:id="medicalTable" VBox.vgrow="ALWAYS" prefHeight="500">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="60" />
            <TableColumn fx:id="colStudentId" text="Student ID" prefWidth="130" />
            <TableColumn fx:id="colDepartment" text="Department" prefWidth="110" />
            <TableColumn fx:id="colStartDate" text="Start Date" prefWidth="110" />
            <TableColumn fx:id="colEndDate" text="End Date" prefWidth="110" />
            <TableColumn fx:id="colReason" text="Reason" prefWidth="170" />
            <TableColumn fx:id="colStatus" text="Status" prefWidth="100" />
            <TableColumn fx:id="colActions" text="Actions" prefWidth="150" />
        </columns>
    </TableView>

    <!-- Status Bar -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label fx:id="statusLabel" style="-fx-text-fill: #5a6d80; -fx-font-size: 12px;" text="" />
    </HBox>

</VBox>
