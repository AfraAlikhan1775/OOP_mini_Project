<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.controller.techOfficerControllers.AddAttendanceController">

    <content>
        <VBox spacing="18" style="-fx-padding:22; -fx-background-color:#eaf1f8;">

            <Label text="My Attendance"
                   style="-fx-font-size:24px; -fx-font-weight:bold; -fx-text-fill:#0b1f36;" />

            <Label text="Only your year and semester subjects are shown. Theory and practical are shown separately."
                   style="-fx-text-fill:#555;" />

            <VBox fx:id="subjectCardBox" spacing="12" />

            <VBox spacing="12"
                  style="-fx-background-color:white; -fx-padding:18; -fx-background-radius:12; -fx-border-color:#d9e2ec; -fx-border-radius:12;">

                <Label fx:id="titleLabel"
                       text="Select a subject"
                       style="-fx-font-size:18px; -fx-font-weight:bold;" />

                <Label fx:id="percentageLabel"
                       text="0%"
                       style="-fx-font-size:28px; -fx-font-weight:bold; -fx-text-fill:#0b1f36;" />

                <HBox fx:id="barBox" spacing="2" />

                <HBox spacing="18">
                    <Label fx:id="presentLabel" text="Attend: 0" style="-fx-text-fill:#198754; -fx-font-weight:bold;" />
                    <Label fx:id="medicalLabel" text="Medical: 0" style="-fx-text-fill:#0dcaf0; -fx-font-weight:bold;" />
                    <Label fx:id="rejectedMedicalLabel" text="Rejected Medical: 0" style="-fx-text-fill:#fd7e14; -fx-font-weight:bold;" />
                    <Label fx:id="absentLabel" text="Absent: 0" style="-fx-text-fill:#dc3545; -fx-font-weight:bold;" />
                </HBox>

                <TableView fx:id="detailTable" prefHeight="270">
                    <columns>
                        <TableColumn fx:id="idCol" text="Attendance ID" prefWidth="130" />
                        <TableColumn fx:id="dateCol" text="Date" prefWidth="150" />
                        <TableColumn fx:id="sessionCol" text="Session ID" prefWidth="170" />
                        <TableColumn fx:id="statusCol" text="Status" prefWidth="160" />
                    </columns>
                </TableView>

            </VBox>

        </VBox>
    </content>
</ScrollPane>