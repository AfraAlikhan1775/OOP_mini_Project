<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="720" prefWidth="1050"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.controller.techOfficerControllers.AddAttendanceController"
            style="-fx-background-color:#ecf0f1;">

    <top>
        <VBox spacing="8" style="-fx-background-color:#0b1f36; -fx-padding:18;">
            <children>
                <Label text="Add Attendance"
                       style="-fx-text-fill:white; -fx-font-size:24px; -fx-font-weight:bold;" />
                <Label text="Select course details once, then add student registration numbers."
                       style="-fx-text-fill:#dbeafe; -fx-font-size:13px;" />
            </children>
        </VBox>
    </top>

    <center>
        <VBox spacing="18" style="-fx-padding:20;">
            <children>

                <VBox spacing="15" style="-fx-background-color:white; -fx-background-radius:14; -fx-padding:20;">
                    <children>
                        <Label text="Attendance Details"
                               style="-fx-font-size:17px; -fx-font-weight:bold; -fx-text-fill:#0b1f36;" />

                        <GridPane hgap="15" vgap="15">
                            <children>
                                <Label text="Year:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                <ComboBox fx:id="yearBox" prefWidth="180" promptText="Select Year"
                                          GridPane.columnIndex="1" GridPane.rowIndex="0" />

                                <Label text="Semester:" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                                <ComboBox fx:id="semesterBox" prefWidth="180" promptText="Select Semester"
                                          GridPane.columnIndex="3" GridPane.rowIndex="0" />

                                <Label text="Course ID:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                <ComboBox fx:id="courseBox" prefWidth="180" promptText="Select Course"
                                          GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                <Label text="Type:" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                                <ComboBox fx:id="typeBox" prefWidth="180" promptText="Select Type"
                                          GridPane.columnIndex="3" GridPane.rowIndex="1" />

                                <Label text="Session ID:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                <ComboBox fx:id="sessionBox" prefWidth="180" promptText="Select Session"
                                          GridPane.columnIndex="1" GridPane.rowIndex="2" />

                                <Label text="Date:" GridPane.columnIndex="2" GridPane.rowIndex="2" />
                                <DatePicker fx:id="datePicker" prefWidth="180"
                                            GridPane.columnIndex="3" GridPane.rowIndex="2" />
                            </children>
                        </GridPane>
                    </children>
                </VBox>

                <VBox spacing="15" style="-fx-background-color:white; -fx-background-radius:14; -fx-padding:20;">
                    <children>
                        <Label text="Add Students"
                               style="-fx-font-size:17px; -fx-font-weight:bold; -fx-text-fill:#0b1f36;" />

                        <HBox spacing="10">
                            <children>
                                <TextField fx:id="regNoField"
                                           promptText="Enter Reg No: TG/2023/001"
                                           prefWidth="280" />
                                <Button text="+ Add"
                                        onAction="#handleAddStudent"
                                        style="-fx-background-color:#14532d; -fx-text-fill:white; -fx-background-radius:8;" />
                                <Button text="Clear"
                                        onAction="#handleClear"
                                        style="-fx-background-color:#6b7280; -fx-text-fill:white; -fx-background-radius:8;" />
                            </children>
                        </HBox>

                        <TableView fx:id="attendanceTable" prefHeight="280">
                            <columns>
                                <TableColumn fx:id="regNoColumn" text="Registration No" prefWidth="300" />
                                <TableColumn fx:id="statusColumn" text="Status" prefWidth="180" />
                            </columns>
                        </TableView>

                        <HBox spacing="12">
                            <children>
                                <Button text="Finish &amp; Save Attendance"
                                        onAction="#handleFinish"
                                        prefWidth="220"
                                        style="-fx-background-color:#0b1f36; -fx-text-fill:white; -fx-background-radius:8;" />
                                <Label fx:id="messageLabel"
                                       text=""
                                       style="-fx-text-fill:#dc2626; -fx-font-weight:bold;" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

            </children>
        </VBox>
    </center>

</BorderPane>