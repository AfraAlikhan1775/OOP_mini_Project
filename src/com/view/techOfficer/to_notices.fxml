<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="0"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.controller.techOfficerControllers.TONoticeController"
      style="-fx-background-color:#eaf1f8;">

    <HBox alignment="CENTER_LEFT"
          prefHeight="60"
          spacing="12"
          style="-fx-background-color:#0b1f36; -fx-padding:10 20 10 20;">

        <Label text="My Notices 📢"
               textFill="WHITE"
               style="-fx-font-size:18px; -fx-font-weight:bold;" />

        <Region HBox.hgrow="ALWAYS" />

        <TextField fx:id="searchField"
                   prefWidth="260"
                   promptText="Search notice..." />

        <ComboBox fx:id="categoryFilter"
                  prefWidth="140" />

        <Button text="Search"
                onAction="#handleSearch"
                style="-fx-background-color:#122c4a; -fx-text-fill:white; -fx-font-weight:bold;" />

        <Button text="Refresh"
                onAction="#handleRefresh"
                style="-fx-background-color:white; -fx-text-fill:#0b1f36; -fx-font-weight:bold;" />
    </HBox>

    <ScrollPane fitToWidth="true"
                pannable="true"
                VBox.vgrow="ALWAYS"
                style="-fx-background-color:#eaf1f8;">

        <content>
            <VBox fx:id="noticeContainer"
                  spacing="18"
                  style="-fx-background-color:#eaf1f8;">

                <padding>
                    <Insets top="20" right="20" bottom="20" left="20" />
                </padding>

            </VBox>
        </content>
    </ScrollPane>

    <Label fx:id="statusLabel"
           text=""
           style="-fx-background-color:#eaf1f8; -fx-text-fill:#475569; -fx-padding:8 20 8 20;" />

</VBox>