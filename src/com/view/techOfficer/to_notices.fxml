<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="15" style="-fx-padding: 25;"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.controller.techOfficerControllers.TONoticeController">

    <HBox alignment="CENTER_LEFT" spacing="15" styleClass="page-header" style="-fx-background-radius: 12;">
        <padding><Insets top="12" right="20" bottom="12" left="20" /></padding>
        <Label styleClass="page-header-title" text="📢  Notices" />
    </HBox>

    <HBox spacing="12" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" styleClass="search-field" promptText="Search notices..." prefWidth="300" />
        <Button onAction="#handleSearch" styleClass="btn-primary" text="🔍" />
        <ComboBox fx:id="categoryFilter" promptText="Category" prefWidth="150" />
        <Region HBox.hgrow="ALWAYS" />
        <Button onAction="#handleRefresh" styleClass="btn-secondary" text="↻ Refresh" />
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
        <VBox fx:id="noticeContainer" spacing="12" style="-fx-padding: 5;" />
    </ScrollPane>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label fx:id="statusLabel" style="-fx-text-fill: #5a6d80; -fx-font-size: 12px;" text="" />
    </HBox>
</VBox>
