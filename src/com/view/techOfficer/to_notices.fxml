<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="0"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.controller.techOfficerControllers.TONoticeController"
      style="-fx-background-color:#eaf1f8;">

    <HBox alignment="CENTER_LEFT"
          prefHeight="50"
          spacing="12"
          style="-fx-background-color:#0b1f36; -fx-padding:10 20 10 20;">
        <children>
            <Label text="My Notices 📄" textFill="WHITE"
                   style="-fx-font-size:18px; -fx-font-weight:bold;" />

            <Region HBox.hgrow="ALWAYS" />

            <TextField fx:id="searchField" prefWidth="280" promptText="Search notice..." />

            <Button text="🔍"
                    onAction="#handleSearch"
                    style="-fx-background-color:#122c4a; -fx-text-fill:white;" />
        </children>
    </HBox>

    <ScrollPane fitToWidth="true" pannable="true" style="-fx-background-color:#eaf1f8;">
        <content>
            <VBox fx:id="noticeCardBox" spacing="18" style="-fx-background-color:#eaf1f8;">
                <padding>
                    <Insets top="20" right="20" bottom="20" left="20" />
                </padding>
            </VBox>
        </content>
    </ScrollPane>

</VBox>