<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="15" style="-fx-padding: 25;"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.controller.techOfficerControllers.TOTimetableController">

    <HBox alignment="CENTER_LEFT" spacing="15" styleClass="page-header" style="-fx-background-radius: 12;">
        <padding>
            <Insets top="12" right="20" bottom="12" left="20"/>
        </padding>
        <Label styleClass="page-header-title" text="📅 Department Timetables"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="deptLabel" style="-fx-text-fill:white; -fx-font-size:14px;" text="Department: All"/>
    </HBox>

    <Label fx:id="infoLabel"
           style="-fx-text-fill: #5a6d80; -fx-font-size: 13px;"
           text="Showing all department timetables" />

    <Label style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"
           text="Available Timetables" />

    <ScrollPane fitToWidth="true" prefHeight="280" style="-fx-background-color: transparent;">
        <content>
            <VBox fx:id="cardContainer" spacing="15" style="-fx-padding: 5;" />
        </content>
    </ScrollPane>

    <Label style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"
           text="Session Details" />

    <ScrollPane fx:id="sessionScrollPane" fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
        <content>
            <VBox fx:id="sessionContainer" spacing="12" style="-fx-padding: 5;" />
        </content>
    </ScrollPane>

    <HBox alignment="CENTER_LEFT">
        <Label fx:id="statusLabel" style="-fx-text-fill: #5a6d80; -fx-font-size: 12px;" text="" />
    </HBox>

</VBox>