<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="15" style="-fx-padding: 25;"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.controller.techOfficerControllers.TOTimetableController">

    <HBox alignment="CENTER_LEFT" spacing="15" styleClass="page-header" style="-fx-background-radius: 12;">
        <padding><Insets top="12" right="20" bottom="12" left="20" /></padding>
        <Label styleClass="page-header-title" text="📅  Department Timetable" />
        <Region HBox.hgrow="ALWAYS" />
        <Label fx:id="deptLabel" style="-fx-text-fill:white; -fx-font-size:14px;" text="" />
    </HBox>

    <Label fx:id="infoLabel" style="-fx-text-fill: #5a6d80; -fx-font-size: 13px;" text="Showing timetables for your department" />

    <TableView fx:id="groupTable" prefHeight="200">
        <columns>
            <TableColumn fx:id="colGroupId" text="ID" prefWidth="60" />
            <TableColumn fx:id="colDept" text="Department" prefWidth="200" />
            <TableColumn fx:id="colLevel" text="Level" prefWidth="100" />
            <TableColumn fx:id="colSemester" text="Semester" prefWidth="100" />
            <TableColumn fx:id="colSessions" text="Sessions" prefWidth="100" />
            <TableColumn fx:id="colView" text="Action" prefWidth="120" />
        </columns>
    </TableView>

    <Label styleClass="section-title" text="Session Details" />

    <TableView fx:id="sessionTable" VBox.vgrow="ALWAYS" prefHeight="300">
        <columns>
            <TableColumn fx:id="colSubject" text="Subject" prefWidth="150" />
            <TableColumn fx:id="colDay" text="Day" prefWidth="110" />
            <TableColumn fx:id="colStartTime" text="Start Time" prefWidth="100" />
            <TableColumn fx:id="colEndTime" text="End Time" prefWidth="100" />
            <TableColumn fx:id="colLecturer" text="Lecturer" prefWidth="150" />
            <TableColumn fx:id="colRoom" text="Room" prefWidth="100" />
            <TableColumn fx:id="colType" text="Type" prefWidth="100" />
        </columns>
    </TableView>

    <HBox alignment="CENTER_LEFT">
        <Label fx:id="statusLabel" style="-fx-text-fill: #5a6d80; -fx-font-size: 12px;" text="" />
    </HBox>
</VBox>
