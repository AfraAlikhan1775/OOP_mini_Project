<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="18" style="-fx-padding: 25;"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.controller.techOfficerControllers.AddSessionController">

    <HBox alignment="CENTER_LEFT" spacing="10"
          style="-fx-background-color:#0b1f36; -fx-padding:14; -fx-background-radius:12;">
        <Label text="➕ Add Session"
               style="-fx-text-fill:white; -fx-font-size:20px; -fx-font-weight:bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="messageLabel"
               text=""
               style="-fx-text-fill:#dbeafe; -fx-font-size:13px;"/>
        <Button text="Back"
                onAction="#handleBack"
                style="-fx-background-color:#475569; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:8;"/>
    </HBox>

    <VBox spacing="15"
          style="-fx-background-color:white; -fx-padding:18; -fx-background-radius:12; -fx-border-color:#d9e2ec; -fx-border-radius:12;">

        <Label text="Session Details"
               style="-fx-font-size:16px; -fx-font-weight:bold; -fx-text-fill:#0b1f36;"/>

        <HBox spacing="12">
            <ComboBox fx:id="yearBox" promptText="Year" prefWidth="120"/>
            <ComboBox fx:id="semesterBox" promptText="Semester" prefWidth="120"/>
            <ComboBox fx:id="courseBox" promptText="Course ID" prefWidth="180"/>
            <ComboBox fx:id="typeBox" promptText="Type" prefWidth="140"/>
        </HBox>

        <HBox spacing="12">
            <TextField fx:id="sessionIdField" promptText="Session ID (ex: TH1 / PR1)" prefWidth="220"/>
            <TextField fx:id="sessionNameField" promptText="Session Name" prefWidth="280"/>
            <Button text="Add Session"
                    onAction="#handleAddSession"
                    style="-fx-background-color:#16a34a; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:8;"/>
        </HBox>
    </VBox>

    <VBox spacing="12"
          style="-fx-background-color:white; -fx-padding:18; -fx-background-radius:12; -fx-border-color:#d9e2ec; -fx-border-radius:12;"
          VBox.vgrow="ALWAYS">

        <Label text="Added Sessions"
               style="-fx-font-size:16px; -fx-font-weight:bold; -fx-text-fill:#0b1f36;"/>

        <TableView fx:id="sessionTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colCourse" text="Course ID" prefWidth="160"/>
                <TableColumn fx:id="colSessionId" text="Session ID" prefWidth="140"/>
                <TableColumn fx:id="colType" text="Type" prefWidth="130"/>
                <TableColumn fx:id="colSessionName" text="Session Name" prefWidth="250"/>
                <TableColumn fx:id="colYear" text="Year" prefWidth="100"/>
                <TableColumn fx:id="colSemester" text="Semester" prefWidth="100"/>
            </columns>
        </TableView>
    </VBox>

</VBox>