<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.controller.Student.stuProfileController"
            style="-fx-background-color:#eaf1f8;">

    <content>
        <VBox spacing="25" style="-fx-padding:30; -fx-background-color:#eaf1f8;">

            <Label text="Edit Profile"
                   style="-fx-font-size:24px; -fx-font-weight:bold; -fx-text-fill:#0b1f36;"/>

            <VBox spacing="15"
                  style="-fx-background-color:white; -fx-padding:25; -fx-background-radius:10; -fx-border-color:#d9e2ec; -fx-border-radius:10;">

                <Label text="Profile Picture"
                       style="-fx-font-size:18px; -fx-font-weight:bold;"/>

                <HBox spacing="20" alignment="CENTER_LEFT">

                    <ImageView fx:id="profileImage"
                               fitWidth="120"
                               fitHeight="120"
                               preserveRatio="true">
                        <image>
                            <Image url="@../../Resources/images/icon/stu.png"/>
                        </image>
                    </ImageView>

                    <VBox spacing="10">
                        <Button text="Choose Profile Picture"
                                onAction="#chooseProfilePicture"
                                style="-fx-background-color:#0b1f36; -fx-text-fill:white; -fx-font-weight:bold;"/>

                        <Button text="Update Profile Picture"
                                onAction="#updateProfilePicture"
                                style="-fx-background-color:#198754; -fx-text-fill:white; -fx-font-weight:bold;"/>

                        <Label text="This changes only users.profile_pic, not student.image_path."
                               style="-fx-text-fill:#666;"/>
                    </VBox>
                </HBox>
            </VBox>

            <VBox spacing="15"
                  style="-fx-background-color:white; -fx-padding:25; -fx-background-radius:10; -fx-border-color:#d9e2ec; -fx-border-radius:10;">

                <Label text="Change Password"
                       style="-fx-font-size:18px; -fx-font-weight:bold;"/>

                <PasswordField fx:id="oldPasswordField"
                               promptText="Old Password"
                               prefWidth="350"/>

                <PasswordField fx:id="newPasswordField"
                               promptText="New Password"
                               prefWidth="350"/>

                <PasswordField fx:id="confirmPasswordField"
                               promptText="Confirm New Password"
                               prefWidth="350"/>

                <Button text="Update Password"
                        onAction="#updatePassword"
                        style="-fx-background-color:#0b1f36; -fx-text-fill:white; -fx-font-weight:bold;"/>
            </VBox>

            <Label fx:id="messageLabel"
                   text=""
                   style="-fx-text-fill:#198754; -fx-font-size:14px; -fx-font-weight:bold;"/>

        </VBox>
    </content>
</ScrollPane>