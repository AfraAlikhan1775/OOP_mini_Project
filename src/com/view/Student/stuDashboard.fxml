<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="1000.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            style="-fx-background-color:#f5f7fa;">

    <children>

        <!-- Profile Card -->
        <VBox layoutX="720.0" layoutY="25.0" prefHeight="250.0" prefWidth="230.0"
              style="-fx-background-color: #0b1f36; -fx-background-radius: 12; -fx-padding: 20;"
              spacing="10">

            <children>
                <ImageView fitHeight="120.0" fitWidth="120.0" preserveRatio="true"/>
                <Label text="Student Name" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="20.0"/>
                    </font>
                </Label>
                <Label text="student@email.com" textFill="WHITE"/>
                <Label text="Course: ICT" textFill="WHITE"/>
                <Label text="Phone: 0771234567" textFill="WHITE"/>
            </children>
        </VBox>

        <!-- Recent Notices -->
        <VBox layoutX="30.0" layoutY="25.0" prefHeight="250.0" prefWidth="640.0"
              style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 18; -fx-border-color:#d9e2ec; -fx-border-radius:12;"
              spacing="10">

            <children>
                <Label text="Recent Notices">
                    <font>
                        <Font name="System Bold" size="24.0"/>
                    </font>
                </Label>

                <Label text="• Semester exam timetable will be released next week"/>
                <Label text="• Mentor meeting on Friday at 10.00 AM"/>
                <Label text="• Assignment submission deadline extended to Monday"/>

                <Button text="View All Notices"
                        prefWidth="150"
                        style="-fx-background-color:#0b1f36; -fx-text-fill:white;"/>
            </children>
        </VBox>

        <!-- Today Timetable -->
        <VBox layoutX="30.0" layoutY="310.0" prefHeight="260.0" prefWidth="450.0"
              style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 18; -fx-border-color:#d9e2ec; -fx-border-radius:12;"
              spacing="10">

            <children>
                <Label text="Today's Timetable">
                    <font>
                        <Font name="System Bold" size="24.0"/>
                    </font>
                </Label>

                <TableView prefHeight="190.0" prefWidth="410.0">
                    <columns>
                        <TableColumn prefWidth="100.0" text="Time"/>
                        <TableColumn prefWidth="110.0" text="Course Code"/>
                        <TableColumn prefWidth="120.0" text="Course"/>
                        <TableColumn prefWidth="80.0" text="Type"/>
                    </columns>
                </TableView>
            </children>
        </VBox>

        <!-- Mentor Details -->
        <VBox layoutX="510.0" layoutY="310.0" prefHeight="125.0" prefWidth="440.0"
              style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 18; -fx-border-color:#d9e2ec; -fx-border-radius:12;"
              spacing="8">

            <children>
                <Label text="Mentor Details">
                    <font>
                        <Font name="System Bold" size="22.0"/>
                    </font>
                </Label>

                <Label text="Name: Mr. John Silva"/>
                <Label text="Department: ICT"/>
                <Label text="Email: john.silva@fot.com"/>
                <Label text="Contact: 0712345678"/>
            </children>
        </VBox>

        <!-- Course Timetable / Quick Access -->
        <VBox layoutX="510.0" layoutY="455.0" prefHeight="115.0" prefWidth="440.0"
              style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 18; -fx-border-color:#d9e2ec; -fx-border-radius:12;"
              spacing="10">

            <children>
                <Label text="Course Timetable & Quick Access">
                    <font>
                        <Font name="System Bold" size="22.0"/>
                    </font>
                </Label>

                <HBox spacing="12">
                    <children>
                        <Button text="View Full Timetable" style="-fx-background-color:#0b1f36; -fx-text-fill:white;"/>
                        <Button text="My Courses" style="-fx-background-color:#0b1f36; -fx-text-fill:white;"/>
                        <Button text="Results" style="-fx-background-color:#0b1f36; -fx-text-fill:white;"/>
                    </children>
                </HBox>
            </children>
        </VBox>

    </children>
</AnchorPane>