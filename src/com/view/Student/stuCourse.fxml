<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.controller.Student.stuCourseController"
            style="-fx-background-color:#f4f6f8;">

    <top>
        <VBox spacing="6" style="-fx-padding: 10 0 15 0;">
            <children>
                <Label text="My Courses">
                    <font>
                        <Font size="24"/>
                    </font>
                </Label>
                <Label text="View your registered courses, weekly PDF notes and announcements"
                       style="-fx-text-fill:#6b7280;"/>
            </children>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background-color:transparent; -fx-background:transparent;">
            <content>
                <VBox fx:id="courseContainer" spacing="16" style="-fx-padding:10;">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>
                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>