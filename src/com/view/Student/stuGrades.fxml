<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.controller.Student.stuGradesController"
            style="-fx-background-color:#eaf1f8;">

    <content>
        <VBox spacing="18" style="-fx-background-color:#eaf1f8; -fx-padding:20;">

            <HBox alignment="CENTER_LEFT" spacing="12"
                  style="-fx-background-color:#0b1f36; -fx-padding:15; -fx-background-radius:10;">

                <Label text="Student Results"
                       style="-fx-text-fill:white; -fx-font-size:22px; -fx-font-weight:bold;"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Label text="Semester"
                       style="-fx-text-fill:white; -fx-font-weight:bold;"/>

                <ComboBox fx:id="semesterBox" prefWidth="220"/>

                <Button text="Refresh"
                        onAction="#refreshResult"
                        style="-fx-background-color:white; -fx-text-fill:#0b1f36; -fx-font-weight:bold;"/>
            </HBox>

            <VBox spacing="10"
                  style="-fx-background-color:white; -fx-padding:18; -fx-background-radius:10; -fx-border-color:#d9e2ec; -fx-border-radius:10;">

                <Label text="My Result"
                       style="-fx-text-fill:#0b1f36; -fx-font-size:18px; -fx-font-weight:bold;"/>


                <TableView fx:id="myResultTable"
                           prefHeight="72"
                           minHeight="72"
                           maxHeight="72"/>
            </VBox>

            <VBox spacing="10"
                  style="-fx-background-color:white; -fx-padding:18; -fx-background-radius:10; -fx-border-color:#d9e2ec; -fx-border-radius:10;">

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="Whole Batch Result"
                           style="-fx-text-fill:#0b1f36; -fx-font-size:18px; -fx-font-weight:bold;"/>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Button text="View Whole Batch"
                            onAction="#loadBatchResult"
                            style="-fx-background-color:#0b1f36; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:6;"/>
                </HBox>

                <TableView fx:id="batchResultTable"
                           prefHeight="360"/>
            </VBox>

            <Label fx:id="messageLabel"
                   text=""
                   style="-fx-text-fill:#555; -fx-font-size:13px;"/>

        </VBox>
    </content>
</ScrollPane>