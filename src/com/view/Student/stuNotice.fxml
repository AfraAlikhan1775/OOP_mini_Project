<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.controller.Student.stuNoticeController">

    <content>
        <VBox spacing="18" style="-fx-padding: 22; -fx-background-color: #f5f7fa;">

            <Label text="My Notices"
                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #0b1f36;" />

            <Label text="All notices and student-specific notices are shown here."
                   style="-fx-text-fill: #555;" />

            <VBox fx:id="noticeCardBox" spacing="12" />

        </VBox>
    </content>
</ScrollPane>