<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="0"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.controller.Student.stuAttendanceController"
      style="-fx-background-color:#eaf1f8;">

    <HBox alignment="CENTER_LEFT"
          prefHeight="50"
          spacing="12"
          style="-fx-background-color:#0b1f36; -fx-padding:10 20 10 20;">
        <children>
            <Label text="Attendance 📊" textFill="WHITE"
                   style="-fx-font-size:18px; -fx-font-weight:bold;" />
            <Region HBox.hgrow="ALWAYS" />
            <Button text="Check Exam Eligibility"
                    onAction="#handleCheckEligibility"
                    style="-fx-background-color:#198754; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:6;"/>
        </children>
    </HBox>

    <VBox fx:id="mainAttendancePane">
        <ScrollPane fitToWidth="true" style="-fx-background-color:#eaf1f8;">
            <content>
                <VBox spacing="20" style="-fx-background-color:#eaf1f8; -fx-padding:20;">
                    <children>

                        <VBox fx:id="subjectCardBox" spacing="12"/>

                        <VBox spacing="15"
                              style="-fx-background-color:white; -fx-background-radius:8; -fx-border-color:#d9e2ec; -fx-border-radius:8; -fx-padding:20;">
                            <children>

                                <Label fx:id="titleLabel" text="Select a subject to view details"
                                       style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:#0b1f36;"/>

                                <HBox spacing="15">
                                    <children>
                                        <VBox spacing="5" style="-fx-background-color:#e8f4f8; -fx-background-radius:6; -fx-padding:12;">
                                            <Label text="Attendance" style="-fx-font-size:12px; -fx-text-fill:#555;"/>
                                            <Label fx:id="percentageLabel" text="0%" style="-fx-font-size:24px; -fx-font-weight:bold; -fx-text-fill:#0b1f36;"/>
                                        </VBox>

                                        <VBox spacing="5" style="-fx-background-color:#e8f8e8; -fx-background-radius:6; -fx-padding:12;">
                                            <Label text="Present" style="-fx-font-size:12px; -fx-text-fill:#555;"/>
                                            <Label fx:id="presentLabel" text="0" style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:#198754;"/>
                                        </VBox>

                                        <VBox spacing="5" style="-fx-background-color:#e8f0ff; -fx-background-radius:6; -fx-padding:12;">
                                            <Label text="Medical" style="-fx-font-size:12px; -fx-text-fill:#555;"/>
                                            <Label fx:id="medicalLabel" text="0" style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:#0dcaf0;"/>
                                        </VBox>

                                        <VBox spacing="5" style="-fx-background-color:#fff0e8; -fx-background-radius:6; -fx-padding:12;">
                                            <Label text="Rejected Medical" style="-fx-font-size:12px; -fx-text-fill:#555;"/>
                                            <Label fx:id="rejectedMedicalLabel" text="0" style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:#fd7e14;"/>
                                        </VBox>

                                        <VBox spacing="5" style="-fx-background-color:#ffe8e8; -fx-background-radius:6; -fx-padding:12;">
                                            <Label text="Absent" style="-fx-font-size:12px; -fx-text-fill:#555;"/>
                                            <Label fx:id="absentLabel" text="0" style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:#dc3545;"/>
                                        </VBox>
                                    </children>
                                </HBox>

                                <Label text="Attendance Bar" style="-fx-font-size:14px; -fx-font-weight:bold;"/>
                                <HBox fx:id="barBox" spacing="2" style="-fx-background-color:#f0f0f0; -fx-background-radius:6; -fx-padding:4;"/>

                                <Label text="Detailed Records" style="-fx-font-size:14px; -fx-font-weight:bold;"/>
                                <TableView fx:id="detailTable" prefHeight="250">
                                    <columns>
                                        <TableColumn fx:id="idCol" prefWidth="100" text="ID"/>
                                        <TableColumn fx:id="dateCol" prefWidth="120" text="Date"/>
                                        <TableColumn fx:id="sessionCol" prefWidth="150" text="Session"/>
                                        <TableColumn fx:id="statusCol" prefWidth="100" text="Status"/>
                                    </columns>
                                </TableView>

                            </children>
                        </VBox>

                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </VBox>

    <VBox fx:id="eligibilityPane"
          spacing="18"
          visible="false"
          managed="false"
          style="-fx-padding:25; -fx-background-color:#eaf1f8;">

        <HBox alignment="CENTER_LEFT" spacing="12">
            <Button text="← Back"
                    onAction="#handleBackFromEligibility"
                    style="-fx-background-color:#0b1f36; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:6;"/>

            <Label text="Exam Eligibility"
                   style="-fx-font-size:22px; -fx-font-weight:bold; -fx-text-fill:#0b1f36;"/>
        </HBox>

        <Label text="EL = Eligible, NE = Not Eligible. Present and approved medical attendance are counted."
               style="-fx-font-size:13px; -fx-text-fill:#555;"/>

        <TableView fx:id="eligibilityTable" prefHeight="460" prefWidth="20"
                   style="-fx-background-color:white;">
            <columns>
                <TableColumn fx:id="courseCodeCol" text="Course Code" prefWidth="250"/>
                <TableColumn fx:id="eligibilityStatusCol" text="Status" prefWidth="180"/>
            </columns>
        </TableView>

    </VBox>

</VBox>