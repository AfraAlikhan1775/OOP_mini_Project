<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.controller.Student.stuMedicalController">

    <content>
        <VBox spacing="18" style="-fx-padding: 22; -fx-background-color: #f5f7fa;">

            <HBox spacing="12">
                <Label text="Medical Submissions"
                       style="-fx-font-size: 22px; -fx-font-weight: bold;" />

                <Button text="+ Add Medical"
                        onAction="#handleShowAddMedical"
                        style="-fx-background-color: #0b5ed7; -fx-text-fill: white; -fx-background-radius: 8;" />
            </HBox>

            <VBox fx:id="addMedicalBox"
                  spacing="14"
                  style="-fx-background-color: white; -fx-padding: 18; -fx-background-radius: 12; -fx-border-color: #d9e2ec; -fx-border-radius: 12;">

                <Label text="Add New Medical"
                       style="-fx-font-size: 18px; -fx-font-weight: bold;" />

                <HBox spacing="12">
                    <Label text="Medical Type" />
                    <ComboBox fx:id="medicalTypeBox"
                              prefWidth="180"
                              onAction="#handleMedicalTypeChange" />
                </HBox>

                <HBox spacing="12">
                    <DatePicker fx:id="startDatePicker" promptText="Start Date" />
                    <DatePicker fx:id="endDatePicker" promptText="End Date" />

                    <Button text="Load Sessions"
                            onAction="#handleLoadSessions" />
                </HBox>

                <TextArea fx:id="reasonArea"
                          promptText="Reason"
                          prefHeight="75"
                          wrapText="true" />

                <HBox spacing="12">
                    <Button text="Upload Medical Photo/PDF"
                            onAction="#handleChooseFile" />
                    <Label fx:id="fileLabel" text="No file selected" />
                </HBox>

                <VBox fx:id="attendanceMedicalBox" spacing="10">

                    <Label text="Attendance Medical - Select Absent Sessions"
                           style="-fx-font-size: 15px; -fx-font-weight: bold;" />

                    <TableView fx:id="sessionTable"
                               editable="true"
                               prefHeight="250">
                        <columns>
                            <TableColumn fx:id="selectColumn" text="Select" prefWidth="70" />
                            <TableColumn fx:id="dateColumn" text="Date" prefWidth="120" />
                            <TableColumn fx:id="courseColumn" text="Course ID" prefWidth="130" />
                            <TableColumn fx:id="sessionColumn" text="Session" prefWidth="240" />
                            <TableColumn fx:id="typeColumn" text="Type" prefWidth="110" />
                        </columns>
                    </TableView>

                </VBox>

                <VBox fx:id="examMedicalBox"
                      spacing="12"
                      visible="false"
                      managed="false"
                      style="-fx-background-color: #f8fbff; -fx-padding: 14; -fx-background-radius: 10; -fx-border-color:#cfe2ff; -fx-border-radius:10;">

                    <Label text="Exam Medical Details"
                           style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill:#0b1f36;" />

                    <HBox spacing="12">
                        <VBox spacing="5">
                            <Label text="Course" />
                            <ComboBox fx:id="examCourseBox" prefWidth="280" />
                        </VBox>

                        <VBox spacing="5">
                            <Label text="Exam Type" />
                            <ComboBox fx:id="examTypeBox" prefWidth="180" />
                        </VBox>

                        <VBox spacing="5">
                            <Label text="Exam Date" />
                            <DatePicker fx:id="examDatePicker" prefWidth="170" />
                        </VBox>
                    </HBox>

                </VBox>

                <Button text="Submit Medical"
                        onAction="#handleSubmitMedical"
                        style="-fx-background-color: #198754; -fx-text-fill: white; -fx-background-radius: 8;" />

                <Label fx:id="messageLabel" textFill="red" />

            </VBox>

            <VBox fx:id="medicalCardBox" spacing="12" />

        </VBox>
    </content>
</ScrollPane>