<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.controller.Student.StudentController">

    <left>
        <VBox spacing="10" style="-fx-background-color: #0b1f36;" prefWidth="180">
            <padding>
                <Insets top="20" right="10" bottom="20" left="10"/>
            </padding>

            <children>
                <Button text="Attendance" onAction="#handleAttendance"
                        style="-fx-background-color: #0b1f36; -fx-text-fill: white;"/>
                <Button text="Timetable" onAction="#handleTimetable"
                        style="-fx-background-color: #0b1f36; -fx-text-fill: white;"/>
                <Button text="Notice" onAction="#handleNotice"
                        style="-fx-background-color: #0b1f36; -fx-text-fill: white;"/>
                <Button text="Grades" onAction="#handleGrades"
                        style="-fx-background-color: #0b1f36; -fx-text-fill: white;"/>
            </children>
        </VBox>
    </left>

    <top>
        <HBox style="-fx-background-color: #122c4a; -fx-padding: 15;">
        </HBox>
    </top>

    <center>
        <StackPane fx:id="contentArea"/>
    </center>

</BorderPane>
