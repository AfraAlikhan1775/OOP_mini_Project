<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720" prefWidth="1050"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.controller.Student.MedicalSubmissionController"
            style="-fx-background-color:#ecf0f1;">

    <top>
        <VBox spacing="6" style="-fx-background-color:#0b1f36; -fx-padding:18;">
            <Label text="Medical Submission"
                   style="-fx-text-fill:white; -fx-font-size:24px; -fx-font-weight:bold;" />
            <Label text="Submit medical for attendance sessions or missed exams."
                   style="-fx-text-fill:#dbeafe; -fx-font-size:13px;" />
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color:#ecf0f1;">
            <content>
                <VBox spacing="18" style="-fx-padding:20;">

                    <VBox spacing="12" style="-fx-background-color:white; -fx-background-radius:14; -fx-padding:18;">
                        <Label text="Medical Type"
                               style="-fx-font-size:17px; -fx-font-weight:bold; -fx-text-fill:#0b1f36;" />

                        <ComboBox fx:id="medicalTypeBox"
                                  prefWidth="220"
                                  onAction="#handleMedicalTypeChange" />
                    </VBox>

                    <VBox spacing="12" style="-fx-background-color:white; -fx-background-radius:14; -fx-padding:18;">
                        <Label text="Medical Date Range"
                               style="-fx-font-size:17px; -fx-font-weight:bold; -fx-text-fill:#0b1f36;" />

                        <HBox spacing="15">
                            <VBox spacing="5">
                                <Label text="Start Date" />
                                <DatePicker fx:id="startDatePicker" prefWidth="200" />
                            </VBox>

                            <VBox spacing="5">
                                <Label text="End Date" />
                                <DatePicker fx:id="endDatePicker" prefWidth="200" />
                            </VBox>
                        </HBox>
                    </VBox>

                    <VBox fx:id="attendanceBox" spacing="12"
                          style="-fx-background-color:white; -fx-background-radius:14; -fx-padding:18;">

                        <Label text="Attendance Medical - Absent Sessions"
                               style="-fx-font-size:17px; -fx-font-weight:bold; -fx-text-fill:#0b1f36;" />

                        <TableView fx:id="sessionTable" prefHeight="280">
                            <columns>
                                <TableColumn fx:id="colCourse" text="Course" prefWidth="140" />
                                <TableColumn fx:id="colSession" text="Session" prefWidth="220" />
                                <TableColumn fx:id="colType" text="Type" prefWidth="130" />
                                <TableColumn fx:id="colDate" text="Date" prefWidth="140" />
                            </columns>
                        </TableView>
                    </VBox>

                    <VBox fx:id="examBox" spacing="12"
                          visible="false" managed="false"
                          style="-fx-background-color:white; -fx-background-radius:14; -fx-padding:18;">

                        <Label text="Exam Medical Details"
                               style="-fx-font-size:17px; -fx-font-weight:bold; -fx-text-fill:#0b1f36;" />

                        <HBox spacing="15">
                            <VBox spacing="5">
                                <Label text="Course" />
                                <ComboBox fx:id="examCourseBox" prefWidth="300" />
                            </VBox>

                            <VBox spacing="5">
                                <Label text="Exam Type" />
                                <ComboBox fx:id="examTypeBox" prefWidth="190" />
                            </VBox>

                            <VBox spacing="5">
                                <Label text="Exam Date" />
                                <DatePicker fx:id="examDatePicker" prefWidth="180" />
                            </VBox>
                        </HBox>
                    </VBox>

                    <VBox spacing="12" style="-fx-background-color:white; -fx-background-radius:14; -fx-padding:18;">
                        <Label text="Reason"
                               style="-fx-font-size:17px; -fx-font-weight:bold; -fx-text-fill:#0b1f36;" />

                        <TextArea fx:id="reasonArea"
                                  promptText="Enter medical reason"
                                  prefHeight="90"
                                  wrapText="true" />

                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Button text="Choose Medical PDF"
                                    onAction="#handleChooseFile"
                                    style="-fx-background-color:#2563eb; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:8;" />

                            <Label fx:id="fileNameLabel"
                                   text="No file selected"
                                   style="-fx-text-fill:#6b7280;" />
                        </HBox>
                    </VBox>

                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <Button text="Submit Medical"
                                onAction="#handleSubmitMedical"
                                prefWidth="180"
                                style="-fx-background-color:#14532d; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:8;" />

                        <Button text="Clear"
                                onAction="#handleClear"
                                prefWidth="120"
                                style="-fx-background-color:#6b7280; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:8;" />

                        <Label fx:id="messageLabel"
                               text=""
                               style="-fx-text-fill:#dc2626; -fx-font-weight:bold;" />
                    </HBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>