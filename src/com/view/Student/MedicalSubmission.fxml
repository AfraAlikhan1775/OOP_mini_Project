<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="720" prefWidth="1050"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.controller.Student.MedicalSubmissionController"
            style="-fx-background-color:#ecf0f1;">

    <top>
        <VBox spacing="6" style="-fx-background-color:#0b1f36; -fx-padding:18;">
            <children>
                <Label text="Medical Submission"
                       style="-fx-text-fill:white; -fx-font-size:24px; -fx-font-weight:bold;" />
                <Label text="Select absent sessions and submit your medical document."
                       style="-fx-text-fill:#dbeafe; -fx-font-size:13px;" />
            </children>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color:#ecf0f1;">
            <content>
                <VBox spacing="18" style="-fx-padding:20;">
                    <children>

                        <VBox spacing="12" style="-fx-background-color:white; -fx-background-radius:14; -fx-padding:18;">
                            <children>
                                <Label text="Medical Date Range"
                                       style="-fx-font-size:17px; -fx-font-weight:bold; -fx-text-fill:#0b1f36;" />

                                <HBox spacing="15">
                                    <children>
                                        <VBox spacing="5">
                                            <children>
                                                <Label text="Start Date" />
                                                <DatePicker fx:id="startDatePicker" prefWidth="200" />
                                            </children>
                                        </VBox>

                                        <VBox spacing="5">
                                            <children>
                                                <Label text="End Date" />
                                                <DatePicker fx:id="endDatePicker" prefWidth="200" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <VBox spacing="12" style="-fx-background-color:white; -fx-background-radius:14; -fx-padding:18;">
                            <children>
                                <Label text="Absent Sessions"
                                       style="-fx-font-size:17px; -fx-font-weight:bold; -fx-text-fill:#0b1f36;" />

                                <TableView fx:id="sessionTable" prefHeight="300">
                                    <columns>
                                        <TableColumn fx:id="colCourse" text="Course" prefWidth="140" />
                                        <TableColumn fx:id="colSession" text="Session" prefWidth="180" />
                                        <TableColumn fx:id="colType" text="Type" prefWidth="120" />
                                        <TableColumn fx:id="colDate" text="Date" prefWidth="140" />
                                    </columns>
                                </TableView>
                            </children>
                        </VBox>

                        <VBox spacing="12" style="-fx-background-color:white; -fx-background-radius:14; -fx-padding:18;">
                            <children>
                                <Label text="Reason"
                                       style="-fx-font-size:17px; -fx-font-weight:bold; -fx-text-fill:#0b1f36;" />

                                <TextArea fx:id="reasonArea"
                                          promptText="Enter your medical reason"
                                          prefHeight="90"
                                          wrapText="true" />

                                <HBox spacing="12">
                                    <children>
                                        <Button text="Choose Medical File"
                                                onAction="#handleChooseFile"
                                                style="-fx-background-color:#2563eb; -fx-text-fill:white; -fx-background-radius:8;" />

                                        <Label fx:id="fileNameLabel"
                                               text="No file selected"
                                               style="-fx-text-fill:#6b7280;" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <HBox spacing="12">
                            <children>
                                <Button text="Submit Medical"
                                        onAction="#handleSubmitMedical"
                                        prefWidth="180"
                                        style="-fx-background-color:#14532d; -fx-text-fill:white; -fx-background-radius:8;" />

                                <Button text="Clear"
                                        onAction="#handleClear"
                                        prefWidth="120"
                                        style="-fx-background-color:#6b7280; -fx-text-fill:white; -fx-background-radius:8;" />

                                <Label fx:id="messageLabel"
                                       text=""
                                       style="-fx-text-fill:#dc2626; -fx-font-weight:bold;" />
                            </children>
                        </HBox>

                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>