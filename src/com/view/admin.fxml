<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="800" prefWidth="1200" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">

    <left>
        <VBox prefWidth="220" spacing="10" style="-fx-background-color:#0b1f36; -fx-padding:15;">
            <children>
                <Label style="-fx-text-fill:white; -fx-font-size:18;" text="FOT Management" />

                <Label style="-fx-text-fill:#7f9bb3;" text="OVERVIEW" />
                <Button fx:id="dashboardBtn" text="Dashboard" />

                <Label style="-fx-text-fill:#7f9bb3;" text="USERS" />
                <Button text="User Profiles" />
                <Button text="Lecturers" />
                <Button text="Tech Officers" />
                <Button text="Undergraduates" />

                <Label style="-fx-text-fill:#7f9bb3;" text="ACADEMIC" />
                <Button text="Courses" />
                <Button text="Timetables" />
                <Button text="Notices" />
            </children>
        </VBox>
    </left>

    <top>
        <HBox spacing="10" style="-fx-background-color:#0f2a44; -fx-padding:10;">
            <children>
                <Label style="-fx-text-fill:white; -fx-font-size:20;" text="Adddmin Dashboard" />
                <Region HBox.hgrow="ALWAYS" />
                <Label style="-fx-text-fill:white;" text="08 April 2026" />
                <Label style="-fx-text-fill:#00ff99;" text="● Online" />
            </children>
        </HBox>
    </top>

    <center>
        <StackPane fx:id="contentArea">

            <VBox spacing="20" style="-fx-padding:20;">

                <HBox spacing="15">

                    <VBox style="-fx-background-color:#122c4a; -fx-padding:15; -fx-background-radius:10;">
                        <children>
                            <Label style="-fx-text-fill:white;" text="Lecturers" />
                            <Label style="-fx-text-fill:white; -fx-font-size:24;" text="5" />
                            <Label style="-fx-text-fill:#9fb3c8;" text="Active faculty" />
                        </children>
                    </VBox>

                    <VBox style="-fx-background-color:#122c4a; -fx-padding:15; -fx-background-radius:10;">
                        <children>
                            <Label style="-fx-text-fill:white;" text="Tech Officers" />
                            <Label style="-fx-text-fill:white; -fx-font-size:24;" text="4" />
                            <Label style="-fx-text-fill:#9fb3c8;" text="Registered" />
                        </children>
                    </VBox>

                    <VBox style="-fx-background-color:#122c4a; -fx-padding:15; -fx-background-radius:10;">
                        <children>
                            <Label style="-fx-text-fill:white;" text="Undergraduates" />
                            <Label style="-fx-text-fill:white; -fx-font-size:24;" text="20" />
                            <Label style="-fx-text-fill:#9fb3c8;" text="Enrolled" />
                        </children>
                    </VBox>

                    <VBox style="-fx-background-color:#122c4a; -fx-padding:15; -fx-background-radius:10;">
                        <children>
                            <Label style="-fx-text-fill:white;" text="Courses" />
                            <Label style="-fx-text-fill:white; -fx-font-size:24;" text="8" />
                            <Label style="-fx-text-fill:#9fb3c8;" text="This semester" />
                        </children>
                    </VBox>

                </HBox>

                <HBox spacing="20">

                    <VBox prefWidth="400" spacing="10" style="-fx-background-color:#122c4a; -fx-padding:15; -fx-background-radius:10;">
                        <children>
                            <Label style="-fx-text-fill:white;" text="Recent Users" />
                            <ListView fx:id="recentUsersList" prefHeight="200" />
                        </children>
                    </VBox>

                    <VBox prefWidth="400" spacing="10" style="-fx-background-color:#122c4a; -fx-padding:15; -fx-background-radius:10;">
                        <children>
                            <Label style="-fx-text-fill:white;" text="Recent Notices" />
                            <ListView fx:id="recentNoticesList" prefHeight="200" />
                        </children>
                    </VBox>

                </HBox>

                <VBox spacing="10" style="-fx-background-color:#122c4a; -fx-padding:15; -fx-background-radius:10;">

                    <Label style="-fx-text-fill:white;" text="Course Overview" />

                    <TableView fx:id="courseTable" prefHeight="200">

                        <columns>
                            <TableColumn fx:id="colCode" prefWidth="100" text="Code" />
                            <TableColumn fx:id="colName" prefWidth="200" text="Course Name" />
                            <TableColumn fx:id="colCoordinator" prefWidth="150" text="Coordinator" />
                            <TableColumn fx:id="colCredits" prefWidth="80" text="Credits" />
                            <TableColumn fx:id="colStatus" prefWidth="100" text="Status" />
                        </columns>

                    </TableView>

                </VBox>

            </VBox>

        </StackPane>
    </center>

</BorderPane>
