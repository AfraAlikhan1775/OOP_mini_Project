<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="748.0" prefWidth="1300.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.controller.Lecturer.LecturerStudentResultsController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-background-color:#0b1f36; -fx-padding:15;">
            <Label text="Student Eligibility, Marks and Results"
                   style="-fx-text-fill:white; -fx-font-size:24px; -fx-font-weight:bold;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button fx:id="refreshButton"
                    text="Refresh"
                    style="-fx-background-color:#dbeafe; -fx-text-fill:#0b1f36; -fx-font-weight:bold;"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="15"
              style="-fx-background-color:#eaf1f8; -fx-padding:20;">

            <VBox spacing="10"
                  style="-fx-background-color:white; -fx-padding:18; -fx-background-radius:15; -fx-border-color:#d9e2ec; -fx-border-radius:15;">

                <Label text="Filter Results"
                       style="-fx-font-size:20px; -fx-font-weight:bold; -fx-text-fill:#0b1f36;"/>

                <HBox spacing="12" alignment="CENTER_LEFT">

                    <VBox spacing="5">
                        <Label text="Department"/>
                        <ComboBox fx:id="departmentCombo"
                                  prefWidth="180"
                                  promptText="Select Department"/>
                    </VBox>

                    <VBox spacing="5">
                        <Label text="Year"/>
                        <ComboBox fx:id="yearCombo"
                                  prefWidth="120"
                                  promptText="Select Year"/>
                    </VBox>

                    <VBox spacing="5">
                        <Label text="Semester"/>
                        <ComboBox fx:id="semesterCombo"
                                  prefWidth="140"
                                  promptText="Select Semester"/>
                    </VBox>

                    <VBox spacing="5">
                        <Label text="View Type"/>
                        <ComboBox fx:id="resultTypeCombo"
                                  prefWidth="140"
                                  promptText="Marks / Result"/>
                    </VBox>

                    <VBox spacing="5">
                        <Label text=" "/>
                        <Button fx:id="viewButton"
                                text="View"
                                prefWidth="150"
                                style="-fx-background-color:#0b1f36; -fx-text-fill:white; -fx-font-weight:bold;"/>
                    </VBox>

                </HBox>

                <Label fx:id="messageLabel"
                       text=""
                       style="-fx-text-fill:#475569; -fx-font-size:13px;"/>
            </VBox>

            <VBox spacing="10"
                  VBox.vgrow="ALWAYS"
                  style="-fx-background-color:white; -fx-padding:18; -fx-background-radius:15; -fx-border-color:#d9e2ec; -fx-border-radius:15;">

                <Label text="Student Wise Course Marks / Results"
                       style="-fx-font-size:20px; -fx-font-weight:bold; -fx-text-fill:#0b1f36;"/>

                <ScrollPane fitToWidth="true"
                            fitToHeight="true"
                            pannable="true"
                            VBox.vgrow="ALWAYS">

                    <content>
                        <TableView fx:id="resultTable"
                                   prefHeight="500"
                                   prefWidth="1600"/>
                    </content>

                </ScrollPane>
            </VBox>

        </VBox>
    </center>
</BorderPane>