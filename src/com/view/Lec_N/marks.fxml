<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="750" prefWidth="1200"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.controller.Lecturer.LecturerMarksGroupController">

    <!-- TOP BAR -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-background-color:#2c3e50; -fx-padding:15 20;">

            <Label text="Marks Management 📊" textFill="WHITE">
                <font>
                    <Font size="18"/>
                </font>
            </Label>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- SEARCH -->
            <TextField fx:id="searchField"
                       promptText="Search by Course ID / Exam Type..."
                       prefWidth="250"/>

            <Button text="Search"
                    onAction="#handleSearch"
                    style="-fx-background-color:#34495e; -fx-text-fill:white;"/>

            <!-- 🔥 UPDATED BUTTON -->
            <Button text="+ Add Attendance / Marks"
                    onAction="#handleCreateGroup"
                    style="-fx-background-color:#0b1f36; -fx-text-fill:white; -fx-font-weight:bold;"/>
        </HBox>
    </top>

    <!-- CENTER CONTENT -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color:#f4f6f8;">
            <content>
                <VBox fx:id="cardContainer"
                      spacing="18"
                      style="-fx-padding:20;">
                </VBox>
            </content>
        </ScrollPane>
    </center>

    <!-- STATUS BAR -->
    <bottom>
        <HBox style="-fx-padding:10 20;">
            <Label fx:id="statusLabel"
                   textFill="#5a6d80"
                   style="-fx-font-size:12px;"/>
        </HBox>
    </bottom>

</BorderPane>