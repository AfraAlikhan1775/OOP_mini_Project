<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.controller.Lecturer.LecturerProfileController"
            style="-fx-background-color:#eaf1f8;">

    <content>
        <VBox spacing="22" style="-fx-padding:30; -fx-background-color:#eaf1f8;">

            <HBox alignment="CENTER_LEFT"
                  style="-fx-background-color:#0b1f36; -fx-padding:18; -fx-background-radius:12;">
                <Label text="👤 My Profile"
                       style="-fx-text-fill:white; -fx-font-size:22px; -fx-font-weight:bold;"/>
            </HBox>

            <VBox spacing="18"
                  style="-fx-background-color:white; -fx-padding:25; -fx-background-radius:12; -fx-border-color:#d9e2ec; -fx-border-radius:12;">

                <HBox alignment="CENTER_LEFT" spacing="25">

                    <ImageView fx:id="profileImage"
                               fitWidth="130"
                               fitHeight="130"
                               preserveRatio="true">
                        <image>
                            <Image url="@../../Resources/images/icon/stu.png"/>
                        </image>
                    </ImageView>

                    <VBox spacing="8">
                        <Label fx:id="nameLabel"
                               text="Lecturer Name"
                               style="-fx-font-size:22px; -fx-font-weight:bold; -fx-text-fill:#0b1f36;"/>

                        <Label fx:id="empIdLabel" text="Employee ID: -"/>
                        <Label fx:id="departmentLabel" text="Department: -"/>
                        <Label fx:id="positionLabel" text="Position: -"/>
                    </VBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <VBox spacing="10">
                        <Button text="Choose Profile Picture"
                                onAction="#chooseProfilePicture"
                                style="-fx-background-color:#0b1f36; -fx-text-fill:white; -fx-font-weight:bold;"/>

                        <Button text="Update Profile Picture"
                                onAction="#updateProfilePicture"
                                style="-fx-background-color:#198754; -fx-text-fill:white; -fx-font-weight:bold;"/>
                    </VBox>
                </HBox>

                <Label text="Profile picture updates only users.profile_pic. Lecturer academic/registration photo is not changed."
                       style="-fx-text-fill:#64748b; -fx-font-size:12px;"/>
            </VBox>

            <HBox spacing="18">

                <VBox spacing="10"
                      HBox.hgrow="ALWAYS"
                      style="-fx-background-color:white; -fx-padding:22; -fx-background-radius:12; -fx-border-color:#d9e2ec; -fx-border-radius:12;">

                    <Label text="Personal Information"
                           style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:#0b1f36;"/>

                    <Label fx:id="nicLabel" text="NIC: -"/>
                    <Label fx:id="dobLabel" text="DOB: -"/>
                    <Label fx:id="genderLabel" text="Gender: -"/>
                    <Label fx:id="addressLabel" text="Address: -" wrapText="true"/>
                </VBox>

                <VBox spacing="10"
                      HBox.hgrow="ALWAYS"
                      style="-fx-background-color:white; -fx-padding:22; -fx-background-radius:12; -fx-border-color:#d9e2ec; -fx-border-radius:12;">

                    <Label text="Contact and Academic Information"
                           style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:#0b1f36;"/>

                    <Label fx:id="emailLabel" text="Email: -"/>
                    <Label fx:id="phoneLabel" text="Phone: -"/>
                    <Label fx:id="specializationLabel" text="Specialization: -"/>
                </VBox>

            </HBox>

            <VBox spacing="14"
                  style="-fx-background-color:white; -fx-padding:22; -fx-background-radius:12; -fx-border-color:#d9e2ec; -fx-border-radius:12;">

                <Label text="Change Password"
                       style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:#0b1f36;"/>

                <PasswordField fx:id="oldPasswordField"
                               promptText="Old Password"
                               maxWidth="380"/>

                <PasswordField fx:id="newPasswordField"
                               promptText="New Password"
                               maxWidth="380"/>

                <PasswordField fx:id="confirmPasswordField"
                               promptText="Confirm New Password"
                               maxWidth="380"/>

                <Button text="Update Password"
                        onAction="#updatePassword"
                        style="-fx-background-color:#0b1f36; -fx-text-fill:white; -fx-font-weight:bold;"
                        maxWidth="180"/>
            </VBox>

            <Label fx:id="statusLabel"
                   text=""
                   style="-fx-font-size:14px; -fx-font-weight:bold;"/>

        </VBox>
    </content>
</ScrollPane>