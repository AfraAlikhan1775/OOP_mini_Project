<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.controller.Lecturer.LecturerCoursesController"
            style="-fx-background-color:#eaf1f8;">

    <top>
        <VBox spacing="8" style="-fx-padding: 18 20 15 20;">
            <children>
                <Label text="My Courses">
                    <font>
                        <Font size="24"/>
                    </font>
                </Label>
                <Label text="Upload PDF notes and add weekly announcements for each course"
                       style="-fx-text-fill:#607080;"/>
            </children>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background-color:transparent; -fx-background:transparent;">
            <content>
                <VBox fx:id="courseCardContainer" spacing="18" style="-fx-padding: 20;">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>
                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>