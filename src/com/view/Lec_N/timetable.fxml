<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="18"
      style="-fx-padding:20; -fx-background-color:#eaf1f8;"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.controller.Lecturer.TimetableController">

    <HBox alignment="CENTER_LEFT"
          spacing="12"
          style="-fx-background-color:#0b1f36; -fx-padding:15; -fx-background-radius:10;">

        <Label fx:id="titleLabel"
               text="My Timetable"
               style="-fx-text-fill:white; -fx-font-size:22px; -fx-font-weight:bold;"/>

        <Region HBox.hgrow="ALWAYS"/>

        <Label text="Day"
               style="-fx-text-fill:white; -fx-font-weight:bold;"/>

        <ComboBox fx:id="dayFilter"
                  prefWidth="160"/>

        <Button text="Refresh"
                onAction="#handleRefresh"
                style="-fx-background-color:white; -fx-text-fill:#0b1f36; -fx-font-weight:bold;"/>
    </HBox>

    <VBox spacing="10"
          style="-fx-background-color:white; -fx-padding:18; -fx-background-radius:10; -fx-border-color:#d9e2ec; -fx-border-radius:10;">

        <Label text="Timetable sessions assigned to you"
               style="-fx-font-size:16px; -fx-font-weight:bold; -fx-text-fill:#0b1f36;"/>

        <TableView fx:id="timetableTable"
                   prefHeight="420">

            <columns>
                <TableColumn fx:id="colDay"
                             text="Day"
                             prefWidth="130"/>

                <TableColumn fx:id="colSubject"
                             text="Subject"
                             prefWidth="240"/>

                <TableColumn fx:id="colTime"
                             text="Time"
                             prefWidth="160"/>

                <TableColumn fx:id="colRoom"
                             text="Room"
                             prefWidth="130"/>

                <TableColumn fx:id="colType"
                             text="Type"
                             prefWidth="140"/>
            </columns>
        </TableView>

        <Label fx:id="statusLabel"
               text=""
               style="-fx-text-fill:#475569; -fx-font-size:13px;"/>
    </VBox>

</VBox>