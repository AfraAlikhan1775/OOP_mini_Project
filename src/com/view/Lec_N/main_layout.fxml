<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="800.0"
            prefWidth="1200.0"
            style="-fx-background-color:#f8fafc;"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.controller.Lecturer.MainController">

    <top>
        <HBox alignment="CENTER_LEFT"
              spacing="12"
              style="-fx-background-color:#0b1f36; -fx-padding:14 20 14 20;">

            <Label text="Lecturer Dashboard"
                   style="-fx-text-fill:white; -fx-font-size:22px; -fx-font-weight:bold;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label text="Lecturer:"
                   style="-fx-text-fill:#cbd5e1; -fx-font-size:13px;"/>

            <Label fx:id="lecturerNameLabel"
                   text="-"
                   style="-fx-text-fill:white; -fx-font-size:14px; -fx-font-weight:bold;"/>
        </HBox>
    </top>

    <left>
        <VBox prefWidth="240"
              spacing="10"
              style="-fx-background-color:#102a43; -fx-padding:20;">

            <Button text="🏠 Dashboard"
                    onAction="#handleDashboard"
                    maxWidth="Infinity"
                    style="-fx-background-color:#1e3a5f; -fx-text-fill:white; -fx-font-weight:bold; -fx-alignment:center-left; -fx-padding:12;"/>

            <Button text="👤 My Profile"
                    onAction="#handleProfile"
                    maxWidth="Infinity"
                    style="-fx-background-color:#1e3a5f; -fx-text-fill:white; -fx-font-weight:bold; -fx-alignment:center-left; -fx-padding:12;"/>

            <Button text="📅 Timetable"
                    onAction="#handleTimetable"
                    maxWidth="Infinity"
                    style="-fx-background-color:#1e3a5f; -fx-text-fill:white; -fx-font-weight:bold; -fx-alignment:center-left; -fx-padding:12;"/>

            <Button text="📢 Notices"
                    onAction="#handleNotice"
                    maxWidth="Infinity"
                    style="-fx-background-color:#1e3a5f; -fx-text-fill:white; -fx-font-weight:bold; -fx-alignment:center-left; -fx-padding:12;"/>

            <Button text="📝 Marks"
                    onAction="#handleMarks"
                    maxWidth="Infinity"
                    style="-fx-background-color:#1e3a5f; -fx-text-fill:white; -fx-font-weight:bold; -fx-alignment:center-left; -fx-padding:12;"/>

            <Button text="📊 Student Results"
                    onAction="#handleResults"
                    maxWidth="Infinity"
                    style="-fx-background-color:#1e3a5f; -fx-text-fill:white; -fx-font-weight:bold; -fx-alignment:center-left; -fx-padding:12;"/>

            <Button text="✅ Attendance"
                    onAction="#handleAttendance"
                    maxWidth="Infinity"
                    style="-fx-background-color:#1e3a5f; -fx-text-fill:white; -fx-font-weight:bold; -fx-alignment:center-left; -fx-padding:12;"/>
            <Button text="🏥 Medical Requests"
                    onAction="#handleMedical"
                    maxWidth="Infinity"
                    style="-fx-background-color:#1e3a5f; -fx-text-fill:white; -fx-font-weight:bold; -fx-alignment:center-left; -fx-padding:12;"/>

            <Button text="↩ Logout"
                    onAction="#handleLogout"
                    prefWidth="210"
                    style="-fx-background-color:#8b1e1e; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:5; -fx-padding:12;"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Label text="Faculty Management System"
                   style="-fx-text-fill:#94a3b8; -fx-font-size:12px;"/>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea"
                   style="-fx-background-color:#f8fafc;">
            <padding>
                <Insets top="0" right="0" bottom="0" left="0"/>
            </padding>
        </StackPane>
    </center>

</BorderPane>