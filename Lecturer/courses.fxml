<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="486.0" prefWidth="476.0" spacing="12" style="-fx-padding:20;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">

    <Label style="-fx-font-size:20;" text="My Courses" />

    <HBox spacing="10">
        <TextField promptText="Search course..." />
        <Button text="Search" />
        <Button text="+ Add Course" />
    </HBox>

    <TableView>
        <columns>
            <TableColumn text="Course Code" />
            <TableColumn prefWidth="88.66667938232422" text="Course Name" />
            <TableColumn prefWidth="62.6666259765625" text="Semester" />
            <TableColumn prefWidth="88.66670227050781" text="Students" />
            <TableColumn prefWidth="117.33331298828125" text="Special Activities" />
        </columns>
    </TableView>

</VBox>
